---
import "../../styles/global.css";
import Footer from "../../components/Footer.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";

const error = Astro.url.searchParams.get("error");

// Si ya tiene sesión, redirigir
const session = Astro.cookies.get("admin_session")?.value;
if (session) {
  return Astro.redirect("/admin/dashboard");
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>Acceso Admin — EventoVota Unitrópico</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
  </head>
  <body style="display:flex;flex-direction:column;min-height:100vh;">
    <!-- Fondo decorativo institucional -->
    <div
      style="
    position:fixed;inset:0;
    background:radial-gradient(ellipse at 30% 20%, rgba(0, 89, 78, 0.15) 0%, transparent 55%),
               radial-gradient(ellipse at 75% 80%, rgba(181, 161, 96, 0.12) 0%, transparent 55%);
    pointer-events:none;z-index:0;
  "
    >
    </div>

    <div style="display:flex;justify-content:flex-end;padding:1rem 2rem 0;position:relative;z-index:2;">
      <ThemeToggle />
    </div>

    <section
      style="
    position:relative;z-index:1;
    flex:1;
    display:flex;align-items:center;justify-content:center;
    padding:2rem;
  "
    >
      <div style="width:100%;max-width:440px;">
        <!-- Logo / Header -->
        <div style="text-align:center;margin-bottom:2rem;">
          <a
            href="/"
            style="
          display:inline-flex;align-items:center;gap:0.6rem;
          color:var(--clr-text-muted);font-size:0.85rem;font-weight:600;
          text-decoration:none;margin-bottom:2rem;
          transition:var(--transition);
        "
            class="back-link"
          >
            ← Volver al Portal Principal
          </a>

          <div
            style="
          width:74px;height:74px;
          background:var(--gradient-primary);
          border:2px solid var(--clr-accent);
          border-radius:22px;
          display:flex;align-items:center;justify-content:center;
          font-size:2rem;
          margin:0 auto 1.25rem;
          box-shadow:var(--shadow-glow), 0 8px 24px rgba(0,0,0,0.15);
          animation:fadeInUp 0.4s ease;
        "
          >
            🛡️
          </div>

          <h1
            style="font-size:2.1rem;font-weight:800;margin-bottom:0.3rem;animation:fadeInUp 0.5s ease 0.1s both;color:var(--clr-text);"
          >
            Panel de Control
          </h1>
          <p
            style="font-size:0.92rem;color:var(--clr-text-muted);font-weight:500;animation:fadeInUp 0.5s ease 0.15s both;"
          >
            Gestión institucional de categorías, proyectos y resultados en vivo
          </p>
        </div>

        <!-- Card login -->
        <div
          class="card"
          style="
        padding:2.25rem 2.25rem 2rem;
        animation:fadeInUp 0.5s ease 0.2s both;
        border:2px solid var(--clr-accent);
        box-shadow:var(--shadow-lg);
        position:relative;
        overflow:hidden;
      "
        >
          <div style="position:absolute;top:0;left:0;right:0;height:4px;background:linear-gradient(90deg, #00594E 0%, #B5A160 100%);"></div>

          {
            error === "credentials" && (
              <div
                class="alert alert--error mb-3"
                style="animation:fadeIn 0.3s ease;"
              >
                <span>⚠️</span>
                <span>
                  Usuario o contraseña incorrectos. Inténtalo de nuevo.
                </span>
              </div>
            )
          }

          <form
            method="POST"
            action="/api/admin/login"
            id="admin-login-form"
            novalidate
          >
            <div style="display:grid;gap:1.25rem;">
              <!-- Usuario -->
              <div class="form-group">
                <label class="form-label" for="usuario">
                  <span style="display:flex;align-items:center;gap:0.4rem;">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      ><path d="M12 2a5 5 0 1 0 0 10 5 5 0 0 0 0-10z"
                      ></path><path
                        d="M12 14c-7 0-9 3.5-9 5v1h18v-1c0-1.5-2-5-9-5z"
                      ></path></svg
                    >
                    Usuario Institucional
                  </span>
                </label>
                <input
                  id="usuario"
                  class="form-input"
                  type="text"
                  name="usuario"
                  placeholder="admin"
                  required
                  autocomplete="username"
                  style="font-size:1rem;padding:0.9rem 1.1rem;"
                />
              </div>

              <!-- Contraseña -->
              <div class="form-group">
                <label class="form-label" for="password">
                  <span style="display:flex;align-items:center;gap:0.4rem;">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="14"
                      height="14"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      ><rect x="3" y="11" width="18" height="11" rx="2"
                      ></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg
                    >
                    Contraseña
                  </span>
                </label>
                <div style="position:relative;">
                  <input
                    id="password"
                    class="form-input"
                    type="password"
                    name="password"
                    placeholder="••••••••"
                    required
                    autocomplete="current-password"
                    style="font-size:1rem;padding:0.9rem 3.2rem 0.9rem 1.1rem;"
                  />
                  <button
                    type="button"
                    id="toggle-password"
                    style="
                    position:absolute;right:1rem;top:50%;transform:translateY(-50%);
                    background:none;border:none;cursor:pointer;
                    color:var(--clr-text-dim);padding:0.25rem;
                    transition:var(--transition);
                  "
                    aria-label="Mostrar/ocultar contraseña"
                  >
                    <svg
                      id="eye-icon"
                      xmlns="http://www.w3.org/2000/svg"
                      width="18"
                      height="18"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"
                      ></path><circle cx="12" cy="12" r="3"></circle>
                    </svg>
                  </button>
                </div>
              </div>

              <!-- Botón de ingreso -->
              <button
                type="submit"
                id="login-btn"
                class="btn btn--primary btn--full"
                style="margin-top:0.5rem;font-size:1.02rem;padding:1rem;border-radius:100px;font-weight:800;box-shadow:0 6px 20px rgba(0, 89, 78, 0.28);letter-spacing:0.02em;"
              >
                <span id="btn-text">Ingresar al Sistema</span>
                <span id="btn-arrow" style="font-size:1.15rem;transition:transform 0.25s ease;">→</span>
                <span id="btn-spinner" class="spinner hidden"></span>
              </button>
            </div>
          </form>
        </div>

        <!-- Info de acceso -->
        <div
          style="
        margin-top:1.5rem;
        padding:1.1rem 1.4rem;
        background:rgba(0, 89, 78, 0.07);
        border:1.5px solid var(--clr-border);
        border-radius:var(--radius-md);
        animation:fadeInUp 0.5s ease 0.35s both;
      "
        >
          <p
            style="font-size:0.84rem;color:var(--clr-text-muted);margin:0;text-align:center;line-height:1.6;font-weight:500;"
          >
            🔐 Acceso restringido a administradores acreditados de Unitrópico.<br />
            ¿Eres asistente? <a href="/" style="color:var(--clr-primary);font-weight:700;"
              >Regístrate aquí</a
            > o
            <a href="/votacion" style="color:var(--clr-primary);font-weight:700;">
              dirígete a votar</a
            >.
          </p>
        </div>
      </div>
    </section>
    <div style="width:100%;margin-top:auto;position:relative;z-index:2;">
      <Footer />
    </div>
  </body>
</html>

<style>
  .back-link:hover {
    color: var(--clr-text-muted) !important;
    transform: translateX(-3px);
    display: inline-flex;
  }
</style>

<script>
  // Toggle mostrar/ocultar contraseña
  const toggleBtn = document.getElementById("toggle-password")!;
  const passwordInput = document.getElementById("password") as HTMLInputElement;
  const eyeIcon = document.getElementById("eye-icon")!;

  toggleBtn.addEventListener("click", () => {
    const isPassword = passwordInput.type === "password";
    passwordInput.type = isPassword ? "text" : "password";
    eyeIcon.innerHTML = isPassword
      ? `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`
      : `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
    toggleBtn.style.color = isPassword
      ? "var(--clr-primary-light)"
      : "var(--clr-text-dim)";
  });

  // Loading state al enviar
  const form = document.getElementById("admin-login-form") as HTMLFormElement;
  const loginBtn = document.getElementById("login-btn") as HTMLButtonElement;
  const btnText = document.getElementById("btn-text")!;
  const btnArrow = document.getElementById("btn-arrow")!;
  const btnSpinner = document.getElementById("btn-spinner")!;

  form.addEventListener("submit", () => {
    loginBtn.disabled = true;
    btnText.textContent = "Verificando...";
    btnArrow.classList.add("hidden");
    btnSpinner.classList.remove("hidden");
  });
</script>
