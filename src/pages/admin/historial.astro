---
import AdminLayout from "../../layouts/AdminLayout.astro";
import {
  obtenerJornadasHistorial,
  obtenerAsistentes,
  obtenerResultados,
  obtenerJornadaActual,
} from "@lib/db";

const jornadas = await obtenerJornadasHistorial();
const jornadaActual = await obtenerJornadaActual();
const asistentesActuales = await obtenerAsistentes();
const resultadosActuales = await obtenerResultados();
const totalVotosActuales = resultadosActuales.reduce(
  (s, r) => s + r.total_votos,
  0,
);

const estaCerrada = jornadaActual.estado === "CERRADA";
const error = Astro.url.searchParams.get("error");
const exito = Astro.url.searchParams.get("exito");
---

<AdminLayout title="Historial y Cierre de Jornadas" activePage="historial">
  <div style="max-width:1100px;">
    <div
      style="margin-bottom:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;"
    >
      <div>
        <h1 style="font-size:2rem;margin-bottom:0.25rem;">
          Gestión y Cierre de Jornadas Electorales
        </h1>
        <p>
          Administra la jornada activa, archiva sesiones e inicia nuevas
          votaciones de manera independiente
        </p>
      </div>
      <div style="display:flex;gap:0.85rem;flex-wrap:wrap;align-items:center;">
        <button
          type="button"
          id="btn-nueva-jornada"
          class="btn"
          style="background:#B5A160;color:#041815;font-weight:800;padding:0.75rem 1.4rem;border:none;box-shadow:0 4px 14px rgba(181,161,96,0.35);cursor:pointer;"
          onclick="window.abrirModalNuevaJornada()"
        >
          🚀 Iniciar NUEVA Jornada Limpia
        </button>
        <a
          href="/api/admin/exportar-excel"
          target="_blank"
          class="btn"
          style="background:#00594E;color:#fff;font-weight:700;border:1px solid #B5A160;padding:0.75rem 1.4rem;text-decoration:none;"
        >
          📊 Descargar Excel Jornada Actual (.xlsx)
        </a>
      </div>
    </div>

    {
      error && (
        <div class="alert alert--error mb-4">
          <span>⚠️</span> {error}
        </div>
      )
    }

    {
      exito && (
        <div class="alert alert--success mb-4">
          <span>✅</span>
          {exito === "creado" &&
            "Jornada archivada y guardada en el historial exitosamente."}
          {exito === "jornada_cerrada" &&
            "🔒 Jornada archivada y cerrada oficialmente. Formularios de registro y votación inhabilitados."}
          {exito === "nueva_jornada" &&
            "🚀 ¡Nueva jornada de votación iniciada con éxito! Contadores en 0 y formularios habilitados."}
          {exito === "actual_modificada" &&
            "Nombre y descripción de la jornada modificados correctamente."}
          {exito === "jornada_reabierta" &&
            "🔓 Jornada reabierta correctamente. Registro y votación habilitados."}
          {exito === "editado" &&
            "Registro histórico modificado correctamente."}
          {exito === "eliminado" && "Registro histórico eliminado del archivo."}
        </div>
      )
    }

    <!-- Tarjeta de JORNADA ACTUAL -->
    <div
      class="card mb-4"
      style={`border:2px solid ${estaCerrada ? "#e74c3c" : "var(--clr-accent)"};background:linear-gradient(135deg, rgba(0,89,78,0.22) 0%, rgba(181,161,96,0.15) 100%);padding:1.75rem;`}
    >
      <div
        style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1.5rem;"
      >
        <div style="flex:1;min-width:280px;">
          <div
            style="display:flex;align-items:center;gap:0.75rem;flex-wrap:wrap;"
          >
            <span
              style={`background:${estaCerrada ? "#e74c3c" : "var(--clr-accent)"};color:${estaCerrada ? "#fff" : "#041815"};font-weight:800;font-size:0.78rem;padding:0.35rem 0.9rem;border-radius:999px;`}
            >
              {
                estaCerrada
                  ? "🔴 JORNADA CERRADA (VOTACIÓN INHABILITADA)"
                  : "🟢 JORNADA ACTIVA EN VIVO"
              }
            </span>
          </div>
          <h2
            style="font-size:1.65rem;margin-top:0.75rem;color:var(--clr-text);"
          >
            {jornadaActual.nombre}
          </h2>
          <p
            style="color:var(--clr-text-muted);font-size:0.95rem;margin-top:0.25rem;"
          >
            {jornadaActual.descripcion || "Sin descripción adicional"}
          </p>
          <div style="display:flex;gap:1rem;margin-top:1rem;flex-wrap:wrap;">
            <span
              class="badge"
              style="background:var(--clr-surface);color:var(--clr-text);padding:0.45rem 0.95rem;font-size:0.9rem;"
            >
              👥 <strong>{asistentesActuales.length}</strong> Participantes registrados
            </span>
            <span
              class="badge"
              style="background:rgba(181, 161, 96, 0.25);color:var(--clr-accent);padding:0.45rem 0.95rem;font-size:0.9rem;"
            >
              🗳️ <strong>{totalVotosActuales}</strong> Votos emitidos
            </span>
          </div>
        </div>

        <!-- Botones específicos de la Jornada Actual -->
        <div style="display:flex;flex-direction:column;gap:0.65rem;min-width:230px;">
          <button
            type="button"
            class="btn"
            style="border:2px solid #B5A160;background:transparent;color:#B5A160;font-weight:700;width:100%;justify-content:center;cursor:pointer;"
            onclick="window.abrirModalModificarActual()"
          >
            ✏️ Modificar Nombre
          </button>

          {
            !estaCerrada ? (
              <button
                type="button"
                class="btn"
                style="background:#00594E;color:#fff;border:1px solid #B5A160;font-weight:700;width:100%;justify-content:center;cursor:pointer;"
                onclick="window.abrirModalCerrarJornada()"
              >
                🔒 Cerrar y Archivar Jornada
              </button>
            ) : (
              <form
                method="POST"
                action="/api/admin/jornadas"
                style="width:100%;"
              >
                <input type="hidden" name="accion" value="reabrir_jornada" />
                <button
                  type="submit"
                  class="btn"
                  style="border:2px solid #2ecc71;background:transparent;color:#2ecc71;font-weight:700;width:100%;justify-content:center;cursor:pointer;"
                >
                  🔓 Reabrir Votación
                </button>
              </form>
            )
          }
        </div>
      </div>
    </div>

    <!-- Lista del Historial -->
    <div class="card">
      <h2 style="font-size:1.25rem;margin-bottom:1.25rem;">
        Archivo de Jornadas Históricas
      </h2>

      {
        jornadas.length === 0 ? (
          <div style="text-align:center;padding:3rem 1rem;color:var(--clr-text-dim);">
            <p style="font-size:2.5rem;margin-bottom:0.5rem;">📜</p>
            <p>No se han archivado jornadas aún.</p>
            <p style="font-size:0.85rem;margin-top:0.25rem;">
              Al finalizar un evento, presiona "Cerrar y Archivar Jornada"
              arriba.
            </p>
          </div>
        ) : (
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Evento / Jornada</th>
                  <th>Fecha de Cierre (Hora Bogotá)</th>
                  <th>Participantes</th>
                  <th>Total Votos</th>
                  <th>Exportar</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>
                {jornadas.map((j) => (
                  <tr>
                    <td>
                      <strong style="color:var(--clr-text);font-size:1rem;">
                        {j.nombre}
                      </strong>
                      {j.notas && (
                        <p style="font-size:0.8rem;color:var(--clr-text-muted);margin-top:0.2rem;">
                          {j.notas}
                        </p>
                      )}
                    </td>
                    <td style="color:var(--clr-text-muted);font-size:0.88rem;">
                      {new Date(j.fecha_cierre).toLocaleString("es-CO", {
                        timeZone: "America/Bogota",
                        dateStyle: "long",
                        timeStyle: "short",
                      })}{" "}
                      (Bogotá)
                    </td>
                    <td>
                      <span
                        class="badge"
                        style="background:var(--clr-surface);color:var(--clr-text);"
                      >
                        👥 {j.total_asistentes}
                      </span>
                    </td>
                    <td>
                      <span
                        class="badge"
                        style="background:rgba(181, 161, 96, 0.2);color:var(--clr-accent);"
                      >
                        🗳️ {j.total_votos}
                      </span>
                    </td>
                    <td>
                      <a
                        href={`/api/admin/exportar-excel?id=${j.id}`}
                        target="_blank"
                        class="btn btn--outline btn--sm"
                        style="border-color:var(--clr-accent);color:var(--clr-accent);"
                      >
                        📑 Excel (.xlsx)
                      </a>
                    </td>
                    <td style="display:flex;gap:0.5rem;align-items:center;">
                      <button
                        type="button"
                        class="btn btn--outline btn--sm btn-editar-historial"
                        data-id={j.id}
                        data-nombre={j.nombre}
                        data-notas={j.notas || ""}
                        title="Editar nombre/notas"
                      >
                        ✏️
                      </button>
                      <button
                        type="button"
                        class="btn btn--danger btn--sm btn-eliminar-historial"
                        data-id={j.id}
                        data-nombre={j.nombre}
                        title="Eliminar del historial"
                      >
                        🗑️
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </div>
  </div>

  <!-- MODAL 1: MODIFICAR JORNADA ACTUAL -->
  <div
    id="modal-modificar-actual"
    class="custom-modal-overlay"
    style="display:none;"
  >
    <div class="custom-modal-box">
      <h3 style="font-size:1.3rem;margin-bottom:0.5rem;color:var(--clr-text);">
        ✏️ Modificar Jornada Actual
      </h3>
      <p
        style="color:var(--clr-text-muted);font-size:0.9rem;margin-bottom:1.25rem;"
      >
        Actualiza el título y la descripción de la jornada en vivo.
      </p>
      <form
        method="POST"
        action="/api/admin/jornadas"
        style="display:flex;flex-direction:column;gap:1rem;"
      >
        <input type="hidden" name="accion" value="modificar_actual" />
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);"
            >Nombre / Título *</label
          >
          <input
            type="text"
            name="nombre"
            class="form-input"
            value={jornadaActual.nombre}
            required
          />
        </div>
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);"
            >Descripción o Notas (Opcional)</label
          >
          <input
            type="text"
            name="notas"
            class="form-input"
            value={jornadaActual.descripcion}
          />
        </div>
        <div
          style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:0.75rem;"
        >
          <button type="button" class="btn btn--outline btn-cerrar-modal"
            >Cancelar</button
          >
          <button
            type="submit"
            class="btn btn--primary"
            style="background:var(--clr-primary);color:#fff;"
            >Guardar Cambios</button
          >
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL 2: CERRAR Y ARCHIVAR JORNADA -->
  <div
    id="modal-cerrar-jornada"
    class="custom-modal-overlay"
    style="display:none;"
  >
    <div class="custom-modal-box" style="max-width:500px;">
      <h3 style="font-size:1.35rem;margin-bottom:0.5rem;color:#e67e22;">
        🔒 Cerrar y Archivar Jornada
      </h3>
      <p
        style="color:var(--clr-text-muted);font-size:0.9rem;margin-bottom:1rem;"
      >
        Al cerrar esta jornada, se guardará una copia en el historial y <strong
          >se cerrará el acceso al registro y votación</strong
        > para los participantes.
      </p>

      <div
        style="background:rgba(230, 126, 34, 0.12);border:1px solid #e67e22;border-radius:8px;padding:1rem;margin-bottom:1.5rem;"
      >
        <p style="font-size:1.05rem;font-weight:700;color:var(--clr-text);">
          {jornadaActual.nombre}
        </p>
        <div
          style="display:flex;gap:1.5rem;margin-top:0.6rem;font-size:0.9rem;color:var(--clr-text);"
        >
          <span
            >👥 Registrados: <strong>{asistentesActuales.length}</strong></span
          >
          <span>🗳️ Votos: <strong>{totalVotosActuales}</strong></span>
        </div>
      </div>

      <form
        method="POST"
        action="/api/admin/jornadas"
        style="display:flex;justify-content:flex-end;gap:0.75rem;"
      >
        <input type="hidden" name="accion" value="cerrar_y_archivar" />
        <button type="button" class="btn btn--outline btn-cerrar-modal"
          >Cancelar</button
        >
        <button
          type="submit"
          class="btn btn--primary"
          style="background:#e67e22;color:#fff;font-weight:700;"
        >
          Sí, Cerrar y Archivar
        </button>
      </form>
    </div>
  </div>

  <!-- MODAL 3: INICIAR NUEVA JORNADA LIMPIA -->
  <div
    id="modal-nueva-jornada"
    class="custom-modal-overlay"
    style="display:none;"
  >
    <div class="custom-modal-box" style="max-width:500px;">
      <h3
        style="font-size:1.35rem;margin-bottom:0.5rem;color:var(--clr-accent);"
      >
        🚀 Iniciar Nueva Jornada de Votación
      </h3>
      <p
        style="color:var(--clr-text-muted);font-size:0.9rem;margin-bottom:1.25rem;"
      >
        Esto creará una nueva sesión de votación activa y <strong
          >pondrá los contadores de votos en 0</strong
        >.
      </p>

      <form
        method="POST"
        action="/api/admin/jornadas"
        style="display:flex;flex-direction:column;gap:1rem;"
      >
        <input type="hidden" name="accion" value="iniciar_nueva_jornada" />
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);"
            >Nombre de la Nueva Jornada *</label
          >
          <input
            type="text"
            name="nombre_nuevo"
            class="form-input"
            placeholder="Ej: Feria de Proyectos de Grado 2026-II"
            required
          />
        </div>
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);"
            >Descripción o Notas (Opcional)</label
          >
          <input
            type="text"
            name="notas_nuevo"
            class="form-input"
            placeholder="Ej: Votación de proyectos destacados"
          />
        </div>
        <div
          style="display:flex;align-items:center;gap:0.6rem;margin-top:0.3rem;"
        >
          <input
            type="checkbox"
            name="reiniciar_asistentes"
            value="si"
            id="chk_reiniciar"
          />
          <label
            for="chk_reiniciar"
            style="font-size:0.86rem;color:var(--clr-text);cursor:pointer;"
          >
            Reiniciar también la lista de asistentes (censo electoral desde
            cero)
          </label>
        </div>
        <div
          style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:1rem;"
        >
          <button type="button" class="btn btn--outline btn-cerrar-modal"
            >Cancelar</button
          >
          <button
            type="submit"
            class="btn btn--primary"
            style="background:var(--clr-accent);color:#041815;font-weight:800;"
          >
            🚀 Sí, Iniciar Nueva Jornada
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL 4: EDITAR HISTÓRICO -->
  <div
    id="modal-editar-jornada"
    class="custom-modal-overlay"
    style="display:none;"
  >
    <div class="custom-modal-box">
      <h3 style="font-size:1.25rem;margin-bottom:1rem;color:var(--clr-text);">
        ✏️ Editar Jornada Histórica
      </h3>
      <form
        method="POST"
        action="/api/admin/jornadas"
        style="display:flex;flex-direction:column;gap:1rem;"
      >
        <input type="hidden" name="accion" value="editar" />
        <input type="hidden" name="id" id="edit-jornada-id" value="" />
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);"
            >Nombre / Título *</label
          >
          <input
            type="text"
            name="nombre"
            id="edit-jornada-nombre"
            class="form-input"
            required
          />
        </div>
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);"
            >Notas o Descripción</label
          >
          <input
            type="text"
            name="notas"
            id="edit-jornada-notas"
            class="form-input"
          />
        </div>
        <div
          style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:0.5rem;"
        >
          <button type="button" class="btn btn--outline btn-cerrar-modal"
            >Cancelar</button
          >
          <button type="submit" class="btn btn--primary">Guardar Cambios</button
          >
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL 5: CONFIRMAR ELIMINACIÓN HISTÓRICA -->
  <div
    id="modal-confirmar-eliminar"
    class="custom-modal-overlay"
    style="display:none;"
  >
    <div class="custom-modal-box" style="max-width:440px;">
      <h3 style="font-size:1.25rem;margin-bottom:0.6rem;color:#e74c3c;">
        🗑️ Confirmar Eliminación
      </h3>
      <p style="color:var(--clr-text);font-size:0.95rem;margin-bottom:0.4rem;">
        ¿Estás seguro de que deseas eliminar permanentemente el registro
        histórico: <strong id="eliminar-jornada-nombre"></strong>?
      </p>
      <p
        style="color:var(--clr-text-muted);font-size:0.85rem;margin-bottom:1.5rem;"
      >
        Esta acción no se puede deshacer.
      </p>
      <form
        method="POST"
        action="/api/admin/jornadas"
        style="display:flex;justify-content:flex-end;gap:0.75rem;"
      >
        <input type="hidden" name="accion" value="eliminar" />
        <input type="hidden" name="id" id="eliminar-jornada-id" value="" />
        <button type="button" class="btn btn--outline btn-cerrar-modal"
          >Cancelar</button
        >
        <button type="submit" class="btn btn--danger"
          >Sí, Eliminar Definitivamente</button
        >
      </form>
    </div>
  </div>

  <!-- SCRIPT CON is:inline PARA GARANTIZAR RESPUESTA RÁPIDA SIN PROBLEMAS DE SCOPE -->
  <script is:inline>
    // Funciones globales inmediatas
    window.abrirModalNuevaJornada = function() {
      const modal = document.getElementById("modal-nueva-jornada");
      if (modal) modal.style.display = "flex";
    };
    window.abrirModalModificarActual = function() {
      const modal = document.getElementById("modal-modificar-actual");
      if (modal) modal.style.display = "flex";
    };
    window.abrirModalCerrarJornada = function() {
      const modal = document.getElementById("modal-cerrar-jornada");
      if (modal) modal.style.display = "flex";
    };

    document.addEventListener("DOMContentLoaded", () => {
      // Botón Modificar Actual
      const btnModificar = document.getElementById("btn-modificar-actual");
      if (btnModificar) {
        btnModificar.addEventListener("click", window.abrirModalModificarActual);
      }

      // Botón Cerrar y Archivar
      const btnCerrar = document.getElementById("btn-cerrar-archivar");
      if (btnCerrar) {
        btnCerrar.addEventListener("click", window.abrirModalCerrarJornada);
      }

      // Botón Nueva Jornada
      const btnNueva = document.getElementById("btn-nueva-jornada");
      if (btnNueva) {
        btnNueva.addEventListener("click", window.abrirModalNuevaJornada);
      }

      // Botones Editar Historial
      document.querySelectorAll(".btn-editar-historial").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = e.currentTarget;
          const id = target.getAttribute("data-id");
          const nombre = target.getAttribute("data-nombre");
          const notas = target.getAttribute("data-notas");

          document.getElementById("edit-jornada-id").value = id;
          document.getElementById("edit-jornada-nombre").value = nombre;
          document.getElementById("edit-jornada-notas").value = notas;
          document.getElementById("modal-editar-jornada").style.display =
            "flex";
        });
      });

      // Botones Eliminar Historial
      document.querySelectorAll(".btn-eliminar-historial").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          const target = e.currentTarget;
          const id = target.getAttribute("data-id");
          const nombre = target.getAttribute("data-nombre");

          document.getElementById("eliminar-jornada-id").value = id;
          document.getElementById("eliminar-jornada-nombre").textContent =
            nombre;
          document.getElementById("modal-confirmar-eliminar").style.display =
            "flex";
        });
      });

      // Botones Cerrar cualquier Modal
      document.querySelectorAll(".btn-cerrar-modal").forEach((btn) => {
        btn.addEventListener("click", () => {
          document
            .querySelectorAll(".custom-modal-overlay")
            .forEach((modal) => {
              modal.style.display = "none";
            });
        });
      });

      // Cerrar modal si hacen clic fuera del cuadro
      document.querySelectorAll(".custom-modal-overlay").forEach((overlay) => {
        overlay.addEventListener("click", (e) => {
          if (e.target === overlay) {
            overlay.style.display = "none";
          }
        });
      });
    });
  </script>
</AdminLayout>

<style>
  .mb-4 {
    margin-bottom: 1.75rem;
  }
  .mb-3 {
    margin-bottom: 1rem;
  }

  .custom-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.78);
    backdrop-filter: blur(5px);
    z-index: 99999;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: fadeIn 0.18s ease-out;
  }

  .custom-modal-box {
    width: 100%;
    max-width: 480px;
    background: var(--clr-surface);
    border: 2px solid var(--clr-accent);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.6);
