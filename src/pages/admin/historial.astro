---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { obtenerJornadasHistorial, obtenerAsistentes, obtenerResultados, obtenerJornadaActual } from '@lib/db';

const jornadas = await obtenerJornadasHistorial();
const jornadaActual = await obtenerJornadaActual();
const asistentesActuales = await obtenerAsistentes();
const resultadosActuales = await obtenerResultados();
const totalVotosActuales = resultadosActuales.reduce((s, r) => s + r.total_votos, 0);

const error = Astro.url.searchParams.get('error');
const exito = Astro.url.searchParams.get('exito');
---

<AdminLayout title="Historial y Cierre de Jornadas" activePage="historial">
  <div style="max-width:1100px;">
    <div style="margin-bottom:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
      <div>
        <h1 style="font-size:2rem;margin-bottom:0.25rem;">Gestión y Cierre de Jornadas Electorales</h1>
        <p>Administra la jornada activa, archiva sesiones y descarga reportes Excel oficiales con hora de Bogotá, Colombia</p>
      </div>
      <div>
        <a href="/api/admin/exportar-excel" target="_blank" class="btn btn--primary btn--sm" style="background:var(--clr-primary);color:#fff;">
          📊 Descargar Excel Jornada Actual (.xlsx)
        </a>
      </div>
    </div>

    {error && (
      <div class="alert alert--error mb-4">
        <span>⚠️</span> {error}
      </div>
    )}

    {exito && (
      <div class="alert alert--success mb-4">
        <span>✅</span>
        {exito === 'creado' && 'Jornada archivada y guardada en el historial exitosamente.'}
        {exito === 'nueva_jornada' && '¡Jornada archivada e iniciada nueva jornada limpia con éxito! Contadores y nombre listos para la nueva votación.'}
        {exito === 'actual_modificada' && 'Nombre y descripción de la jornada actual modificados correctamente.'}
        {exito === 'editado' && 'Registro histórico modificado correctamente.'}
        {exito === 'eliminado' && 'Registro histórico eliminado del archivo.'}
      </div>
    )}

    <!-- Tarjeta de JORNADA ACTUAL EN CURSO -->
    <div class="card mb-4" style="border:2px solid var(--clr-accent);background:linear-gradient(135deg, rgba(0,89,78,0.22) 0%, rgba(181,161,96,0.15) 100%);padding:1.75rem;">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:1rem;">
        <div>
          <span style="background:var(--clr-accent);color:#041815;font-weight:800;font-size:0.78rem;padding:0.3rem 0.85rem;border-radius:999px;">
            🟢 JORNADA ACTUAL EN CURSO
          </span>
          <h2 style="font-size:1.6rem;margin-top:0.75rem;color:var(--clr-text);">{jornadaActual.nombre}</h2>
          <p style="color:var(--clr-text-muted);font-size:0.95rem;margin-top:0.25rem;">
            {jornadaActual.descripcion || 'Sin descripción adicional'}
          </p>
          <div style="display:flex;gap:1rem;margin-top:1rem;flex-wrap:wrap;">
            <span class="badge" style="background:var(--clr-surface);color:var(--clr-text);padding:0.4rem 0.9rem;font-size:0.9rem;">
              👥 <strong>{asistentesActuales.length}</strong> Participantes registrados
            </span>
            <span class="badge" style="background:rgba(181, 161, 96, 0.25);color:var(--clr-accent);padding:0.4rem 0.9rem;font-size:0.9rem;">
              🗳️ <strong>{totalVotosActuales}</strong> Votos emitidos
            </span>
          </div>
        </div>

        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;">
          <button
            type="button"
            class="btn btn--outline"
            style="border-color:var(--clr-accent);color:var(--clr-accent);"
            onclick="abrirModalModificarActual()"
          >
            ✏️ Modificar Jornada Actual
          </button>
          <button
            type="button"
            class="btn btn--primary"
            style="background:var(--clr-accent);color:#041815;font-weight:800;"
            onclick="abrirModalConfirmarArchivar()"
          >
            🔒 Archivar e Iniciar Nueva Jornada
          </button>
        </div>
      </div>
    </div>

    <!-- Lista del Historial -->
    <div class="card">
      <h2 style="font-size:1.25rem;margin-bottom:1.25rem;">Archivo de Jornadas Históricas</h2>

      {jornadas.length === 0 ? (
        <div style="text-align:center;padding:3rem 1rem;color:var(--clr-text-dim);">
          <p style="font-size:2.5rem;margin-bottom:0.5rem;">📜</p>
          <p>No se han archivado jornadas aún.</p>
          <p style="font-size:0.85rem;margin-top:0.25rem;">Al finalizar un evento, presiona "Archivar e Iniciar Nueva Jornada" arriba.</p>
        </div>
      ) : (
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Evento / Jornada</th>
                <th>Fecha de Cierre (Hora Bogotá)</th>
                <th>Participantes</th>
                <th>Total Votos</th>
                <th>Exportar</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {jornadas.map(j => (
                <tr>
                  <td>
                    <strong style="color:var(--clr-text);font-size:1rem;">{j.nombre}</strong>
                    {j.notas && <p style="font-size:0.8rem;color:var(--clr-text-muted);margin-top:0.2rem;">{j.notas}</p>}
                  </td>
                  <td style="color:var(--clr-text-muted);font-size:0.88rem;">
                    {new Date(j.fecha_cierre).toLocaleString('es-CO', { timeZone: 'America/Bogota', dateStyle: 'long', timeStyle: 'short' })} (Bogotá)
                  </td>
                  <td>
                    <span class="badge" style="background:var(--clr-surface);color:var(--clr-text);">
                      👥 {j.total_asistentes}
                    </span>
                  </td>
                  <td>
                    <span class="badge" style="background:rgba(181, 161, 96, 0.2);color:var(--clr-accent);">
                      🗳️ {j.total_votos}
                    </span>
                  </td>
                  <td>
                    <a
                      href={`/api/admin/exportar-excel?id=${j.id}`}
                      target="_blank"
                      class="btn btn--outline btn--sm"
                      style="border-color:var(--clr-accent);color:var(--clr-accent);"
                    >
                      📑 Excel (.xlsx)
                    </a>
                  </td>
                  <td style="display:flex;gap:0.5rem;align-items:center;">
                    <button
                      type="button"
                      class="btn btn--outline btn--sm"
                      title="Editar nombre/notas"
                      onclick={`abrirModalEditar(${j.id}, ${JSON.stringify(j.nombre)}, ${JSON.stringify(j.notas || '')})`}
                    >
                      ✏️
                    </button>
                    <button
                      type="button"
                      class="btn btn--danger btn--sm"
                      title="Eliminar del historial"
                      onclick={`abrirModalConfirmarEliminar(${j.id}, ${JSON.stringify(j.nombre)})`}
                    >
                      🗑️
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>

  <!-- MODAL 1: MODIFICAR JORNADA ACTUAL -->
  <div id="modal-modificar-actual" class="custom-modal-overlay" style="display:none;">
    <div class="custom-modal-box">
      <h3 style="font-size:1.3rem;margin-bottom:0.5rem;color:var(--clr-text);">✏️ Modificar Jornada Actual en Curso</h3>
      <p style="color:var(--clr-text-muted);font-size:0.9rem;margin-bottom:1.25rem;">
        Actualiza el título y la descripción del evento actualmente en vivo.
      </p>
      <form method="POST" action="/api/admin/jornadas" style="display:flex;flex-direction:column;gap:1rem;">
        <input type="hidden" name="accion" value="modificar_actual" />
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);">Nombre / Título de la Jornada *</label>
          <input type="text" name="nombre" class="form-input" defaultValue={jornadaActual.nombre} required />
        </div>
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);">Descripción o Notas (Opcional)</label>
          <input type="text" name="notas" class="form-input" defaultValue={jornadaActual.descripcion} />
        </div>
        <div style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:0.75rem;">
          <button type="button" class="btn btn--outline" onclick="cerrarModalModificarActual()">Cancelar</button>
          <button type="submit" class="btn btn--primary" style="background:var(--clr-primary);color:#fff;">Guardar Cambios</button>
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL 2: CONFIRMAR ARCHIVO E INICIAR NUEVA JORNADA -->
  <div id="modal-confirmar-archivar" class="custom-modal-overlay" style="display:none;">
    <div class="custom-modal-box" style="max-width:540px;">
      <h3 style="font-size:1.35rem;margin-bottom:0.5rem;color:var(--clr-accent);">🔒 Confirmar Archivo e Iniciar Nueva Jornada</h3>
      <p style="color:var(--clr-text-muted);font-size:0.9rem;margin-bottom:1rem;">
        Por favor revisa y confirma los datos antes de archivar la jornada en curso.
      </p>

      <div style="background:rgba(0, 89, 78, 0.15);border:1px solid var(--clr-accent);border-radius:8px;padding:1rem;margin-bottom:1.25rem;">
        <p style="font-size:0.85rem;color:var(--clr-text-muted);margin-bottom:0.3rem;">SE ARCHIVARÁ LA JORNADA ACTUAL:</p>
        <p style="font-size:1.1rem;font-weight:700;color:var(--clr-text);">{jornadaActual.nombre}</p>
        {jornadaActual.descripcion && <p style="font-size:0.88rem;color:var(--clr-text-muted);">{jornadaActual.descripcion}</p>}
        <div style="display:flex;gap:1rem;margin-top:0.6rem;font-size:0.88rem;color:var(--clr-text);">
          <span>👥 Participantes: <strong>{asistentesActuales.length}</strong></span>
          <span>🗳️ Votos emitidos: <strong>{totalVotosActuales}</strong></span>
        </div>
      </div>

      <form method="POST" action="/api/admin/jornadas" style="display:flex;flex-direction:column;gap:1rem;">
        <input type="hidden" name="accion" value="crear_y_reiniciar" />
        <input type="hidden" name="nombre_actual" value={jornadaActual.nombre} />
        <input type="hidden" name="notas_actual" value={jornadaActual.descripcion} />

        <div style="border-top:1px solid var(--clr-border);padding-top:1rem;">
          <h4 style="font-size:1rem;margin-bottom:0.75rem;color:var(--clr-text);">Configuración de la NUEVA Jornada *</h4>
          <div class="form-group mb-3">
            <label class="form-label" style="color:var(--clr-text);">Nombre de la Nueva Jornada *</label>
            <input
              type="text"
              name="nombre_nuevo"
              class="form-input"
              placeholder="Ej: Jornada Electoral Ingeniería 2026-II"
              required
            />
          </div>
          <div class="form-group mb-3">
            <label class="form-label" style="color:var(--clr-text);">Descripción de la Nueva Jornada (Opcional)</label>
            <input
              type="text"
              name="notas_nuevo"
              class="form-input"
              placeholder="Ej: Votación de proyectos destacados"
            />
          </div>
          <div style="display:flex;align-items:center;gap:0.6rem;">
            <input type="checkbox" name="reiniciar_asistentes" value="si" id="chk_reiniciar_asistentes" />
            <label for="chk_reiniciar_asistentes" style="font-size:0.86rem;color:var(--clr-text);cursor:pointer;">
              Reiniciar también la lista de asistentes registrados (censo desde cero)
            </label>
          </div>
        </div>

        <div style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:0.75rem;">
          <button type="button" class="btn btn--outline" onclick="cerrarModalConfirmarArchivar()">Cancelar</button>
          <button type="submit" class="btn btn--primary" style="background:var(--clr-accent);color:#041815;font-weight:800;">
            ✅ Sí, Archivar e Iniciar Nueva Jornada
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL 3: EDITAR REGISTRO HISTÓRICO -->
  <div id="modal-editar-jornada" class="custom-modal-overlay" style="display:none;">
    <div class="custom-modal-box">
      <h3 style="font-size:1.25rem;margin-bottom:1rem;color:var(--clr-text);">✏️ Editar Jornada Histórica</h3>
      <form method="POST" action="/api/admin/jornadas" style="display:flex;flex-direction:column;gap:1rem;">
        <input type="hidden" name="accion" value="editar" />
        <input type="hidden" name="id" id="edit-jornada-id" value="" />
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);">Nombre / Título de la Jornada *</label>
          <input type="text" name="nombre" id="edit-jornada-nombre" class="form-input" required />
        </div>
        <div class="form-group">
          <label class="form-label" style="color:var(--clr-text);">Notas o Descripción</label>
          <input type="text" name="notas" id="edit-jornada-notas" class="form-input" />
        </div>
        <div style="display:flex;justify-content:flex-end;gap:0.75rem;margin-top:0.5rem;">
          <button type="button" class="btn btn--outline" onclick="cerrarModalEditar()">Cancelar</button>
          <button type="submit" class="btn btn--primary">Guardar Cambios</button>
        </div>
      </form>
    </div>
  </div>

  <!-- MODAL 4: CONFIRMAR ELIMINACIÓN HISTÓRICA -->
  <div id="modal-confirmar-eliminar" class="custom-modal-overlay" style="display:none;">
    <div class="custom-modal-box" style="max-width:440px;">
      <h3 style="font-size:1.25rem;margin-bottom:0.6rem;color:#e74c3c;">🗑️ Confirmar Eliminación</h3>
      <p style="color:var(--clr-text);font-size:0.95rem;margin-bottom:0.4rem;">
        ¿Estás seguro de que deseas eliminar permanentemente el registro histórico: <strong id="eliminar-jornada-nombre"></strong>?
      </p>
      <p style="color:var(--clr-text-muted);font-size:0.85rem;margin-bottom:1.5rem;">
        Esta acción no se puede deshacer.
      </p>
      <form method="POST" action="/api/admin/jornadas" style="display:flex;justify-content:flex-end;gap:0.75rem;">
        <input type="hidden" name="accion" value="eliminar" />
        <input type="hidden" name="id" id="eliminar-jornada-id" value="" />
        <button type="button" class="btn btn--outline" onclick="cerrarModalConfirmarEliminar()">Cancelar</button>
        <button type="submit" class="btn btn--danger">Sí, Eliminar Definitivamente</button>
      </form>
    </div>
  </div>

  <script>
    function abrirModalModificarActual() {
      const modal = document.getElementById('modal-modificar-actual');
      if (modal) modal.style.display = 'flex';
    }
    function cerrarModalModificarActual() {
      const modal = document.getElementById('modal-modificar-actual');
      if (modal) modal.style.display = 'none';
    }

    function abrirModalConfirmarArchivar() {
      const modal = document.getElementById('modal-confirmar-archivar');
      if (modal) modal.style.display = 'flex';
    }
    function cerrarModalConfirmarArchivar() {
      const modal = document.getElementById('modal-confirmar-archivar');
      if (modal) modal.style.display = 'none';
    }

    function abrirModalEditar(id: number, nombre: string, notas: string) {
      const modal = document.getElementById('modal-editar-jornada');
      const inputId = document.getElementById('edit-jornada-id') as HTMLInputElement;
      const inputNombre = document.getElementById('edit-jornada-nombre') as HTMLInputElement;
      const inputNotas = document.getElementById('edit-jornada-notas') as HTMLInputElement;

      if (modal && inputId && inputNombre && inputNotas) {
        inputId.value = String(id);
        inputNombre.value = nombre;
        inputNotas.value = notas;
        modal.style.display = 'flex';
      }
    }
    function cerrarModalEditar() {
      const modal = document.getElementById('modal-editar-jornada');
      if (modal) modal.style.display = 'none';
    }

    function abrirModalConfirmarEliminar(id: number, nombre: string) {
      const modal = document.getElementById('modal-confirmar-eliminar');
      const inputId = document.getElementById('eliminar-jornada-id') as HTMLInputElement;
      const labelNombre = document.getElementById('eliminar-jornada-nombre');

      if (modal && inputId && labelNombre) {
        inputId.value = String(id);
        labelNombre.textContent = nombre;
        modal.style.display = 'flex';
      }
    }
    function cerrarModalConfirmarEliminar() {
      const modal = document.getElementById('modal-confirmar-eliminar');
      if (modal) modal.style.display = 'none';
    }

    (window as any).abrirModalModificarActual = abrirModalModificarActual;
    (window as any).cerrarModalModificarActual = cerrarModalModificarActual;
    (window as any).abrirModalConfirmarArchivar = abrirModalConfirmarArchivar;
    (window as any).cerrarModalConfirmarArchivar = cerrarModalConfirmarArchivar;
    (window as any).abrirModalEditar = abrirModalEditar;
    (window as any).cerrarModalEditar = cerrarModalEditar;
    (window as any).abrirModalConfirmarEliminar = abrirModalConfirmarEliminar;
    (window as any).cerrarModalConfirmarEliminar = cerrarModalConfirmarEliminar;
  </script>
</AdminLayout>

<style>
  .mb-4 { margin-bottom: 1.75rem; }
  .mb-3 { margin-bottom: 1rem; }

  .custom-modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    z-index: 99999;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    animation: fadeIn 0.2s ease-out;
  }

  .custom-modal-box {
    width: 100%;
    max-width: 480px;
    background: var(--clr-surface);
    border: 2px solid var(--clr-accent);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.5);
    animation: scaleUp 0.2s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes scaleUp {
    from { transform: scale(0.95); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }
</style>
