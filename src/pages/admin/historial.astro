---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { obtenerJornadasHistorial, obtenerAsistentes, obtenerResultados } from '@lib/db';

const jornadas = await obtenerJornadasHistorial();
const asistentesActuales = await obtenerAsistentes();
const resultadosActuales = await obtenerResultados();
const totalVotosActuales = resultadosActuales.reduce((s, r) => s + r.total_votos, 0);

const error = Astro.url.searchParams.get('error');
const exito = Astro.url.searchParams.get('exito');
---

<AdminLayout title="Historial y Cierre de Jornadas" activePage="historial">
  <div style="max-width:1100px;">
    <div style="margin-bottom:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
      <div>
        <h1 style="font-size:2rem;margin-bottom:0.25rem;">Historial de Jornadas Electorales</h1>
        <p>Cierra, archiva y descarga reportes Excel estéticos de las votaciones de Unitrópico</p>
      </div>
      <div>
        <a href="/api/admin/exportar-excel" target="_blank" class="btn btn--primary btn--sm" style="background:var(--clr-primary);color:#fff;">
          📊 Descargar Excel Jornada Actual (.xlsx)
        </a>
      </div>
    </div>

    {error && (
      <div class="alert alert--error mb-4">
        <span>⚠️</span> {error}
      </div>
    )}

    {exito && (
      <div class="alert alert--success mb-4">
        <span>✅</span>
        {exito === 'creado' && 'Jornada archivada y guardada en el historial exitosamente.'}
        {exito === 'editado' && 'Registro histórico modificado correctamente.'}
        {exito === 'eliminado' && 'Registro histórico eliminado del archivo.'}
      </div>
    )}

    <!-- Tarjeta para Cierre de Jornada Actual -->
    <div class="card mb-4" style="border:1px solid var(--clr-accent);background:linear-gradient(135deg, rgba(0,89,78,0.25) 0%, rgba(181,161,96,0.1) 100%);">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1.5rem;">
        <div>
          <span style="background:var(--clr-accent);color:#041815;font-weight:800;font-size:0.75rem;padding:0.25rem 0.7rem;border-radius:999px;">
            📸 SNAPSHOT DE JORNADA EN VIVO
          </span>
          <h2 style="font-size:1.35rem;margin-top:0.6rem;color:var(--clr-text);">Cerrar y Archivar Jornada Actual</h2>
          <p style="color:var(--clr-text-muted);font-size:0.9rem;margin-top:0.25rem;">
            Se congelará una fotografía de los {asistentesActuales.length} participantes y {totalVotosActuales} votos actuales.
          </p>
        </div>
        <form method="POST" action="/api/admin/jornadas" style="display:flex;gap:0.75rem;flex-wrap:wrap;align-items:center;">
          <input type="hidden" name="accion" value="crear" />
          <input
            type="text"
            name="nombre"
            class="form-input"
            placeholder="Ej: Feria de Proyectos 2026-I"
            required
            style="min-width:250px;margin:0;"
          />
          <button type="submit" class="btn btn--primary" style="background:var(--clr-accent);color:#041815;font-weight:800;white-space:nowrap;">
            🔒 Archivar Jornada
          </button>
        </form>
      </div>
    </div>

    <!-- Lista del Historial -->
    <div class="card">
      <h2 style="font-size:1.25rem;margin-bottom:1.25rem;">Archivo de Jornadas Históricas</h2>

      {jornadas.length === 0 ? (
        <div style="text-align:center;padding:3rem 1rem;color:var(--clr-text-dim);">
          <p style="font-size:2.5rem;margin-bottom:0.5rem;">📜</p>
          <p>No se han archivado jornadas aún.</p>
          <p style="font-size:0.85rem;margin-top:0.25rem;">Haz clic en "Archivar Jornada" para guardar el primer cierre del evento.</p>
        </div>
      ) : (
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Evento / Jornada</th>
                <th>Fecha de Cierre</th>
                <th>Participantes</th>
                <th>Total Votos</th>
                <th>Exportar</th>
                <th>Acciones</th>
              </tr>
            </thead>
            <tbody>
              {jornadas.map(j => (
                <tr>
                  <td>
                    <strong style="color:var(--clr-text);font-size:1rem;">{j.nombre}</strong>
                    {j.notas && <p style="font-size:0.8rem;color:var(--clr-text-muted);margin-top:0.2rem;">{j.notas}</p>}
                  </td>
                  <td style="color:var(--clr-text-muted);font-size:0.88rem;">
                    {new Date(j.fecha_cierre).toLocaleString('es-CO')}
                  </td>
                  <td>
                    <span class="badge" style="background:var(--clr-surface);color:var(--clr-text);">
                      👥 {j.total_asistentes}
                    </span>
                  </td>
                  <td>
                    <span class="badge" style="background:rgba(181, 161, 96, 0.2);color:var(--clr-accent);">
                      🗳️ {j.total_votos}
                    </span>
                  </td>
                  <td>
                    <a
                      href={`/api/admin/exportar-excel?id=${j.id}`}
                      target="_blank"
                      class="btn btn--outline btn--sm"
                      style="border-color:var(--clr-accent);color:var(--clr-accent);"
                    >
                      📑 Excel (.xlsx)
                    </a>
                  </td>
                  <td>
                    <form method="POST" action="/api/admin/jornadas" onsubmit="return confirm('¿Seguro que deseas eliminar este registro histórico?');" style="display:inline;">
                      <input type="hidden" name="accion" value="eliminar" />
                      <input type="hidden" name="id" value={j.id} />
                      <button type="submit" class="btn btn--danger btn--sm" title="Eliminar del historial">
                        🗑️
                      </button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</AdminLayout>

<style>
  .mb-4 { margin-bottom: 1.75rem; }
</style>
