---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { obtenerCategorias, obtenerProyectos } from '@lib/db';

const categorias = await obtenerCategorias();
const proyectos = await obtenerProyectos();
const msg = Astro.url.searchParams.get('msg');
---

<AdminLayout title="Proyectos" activePage="proyectos">
  <div style="max-width:1000px;">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:2rem;">
      <div>
        <h1 style="font-size:2rem;font-weight:800;margin-bottom:0.25rem;color:var(--clr-text);">Proyectos Candidatos</h1>
        <p style="color:var(--clr-text-muted);">Gestiona los proyectos habilitados para la votación institucional</p>
      </div>
      <button class="btn btn--primary" style="border-radius:100px;padding:0.65rem 1.4rem;font-weight:700;box-shadow:0 4px 14px rgba(0, 89, 78, 0.25);" onclick="abrirModal()">
        + Agregar proyecto
      </button>
    </div>

    {msg === 'created' && <div class="alert alert--success mb-3"><span>✅</span> Proyecto creado exitosamente</div>}
    {msg === 'updated' && <div class="alert alert--success mb-3"><span>✅</span> Proyecto actualizado</div>}
    {msg === 'deleted' && <div class="alert alert--success mb-3"><span>✅</span> Proyecto eliminado</div>}

    {categorias.filter(c => c.activa === true).map(cat => {
      const catProyectos = proyectos.filter(p => p.categoria_id === cat.id);
      return (
        <div class="category-section" style="margin-bottom:1.5rem;border:1.5px solid var(--clr-border);">
          <div class="category-header" style="background:rgba(0, 89, 78, 0.08);border-bottom:1px solid var(--clr-border);">
            <h3 style="font-size:1.05rem;font-weight:800;margin:0;color:var(--clr-text);display:flex;align-items:center;gap:0.45rem;">
              <span>🏷️</span> {cat.nombre}
            </h3>
            <span class="badge badge--gold">{catProyectos.length} proyecto{catProyectos.length !== 1 ? 's' : ''}</span>
          </div>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Nombre del Proyecto</th>
                  <th>Descripción</th>
                  <th>Autores / Equipo</th>
                  <th style="text-align:right;">Acciones</th>
                </tr>
              </thead>
              <tbody>
                {catProyectos.length === 0 && (
                  <tr>
                    <td colspan={4} style="text-align:center;color:var(--clr-text-dim);padding:2rem;">
                      Sin proyectos asignados a esta categoría.
                      <button class="btn btn--outline btn--sm" style="margin-left:1rem;border-radius:100px;font-weight:700;" onclick={`abrirModal(null, ${cat.id})`}>
                        + Agregar Primer Proyecto
                      </button>
                    </td>
                  </tr>
                )}
                {catProyectos.map(p => (
                  <tr>
                    <td style="font-weight:700;color:var(--clr-text);">{p.nombre}</td>
                    <td style="color:var(--clr-text-muted);font-size:0.85rem;max-width:260px;">
                      {p.descripcion || <span style="color:var(--clr-text-dim);">—</span>}
                    </td>
                    <td style="font-size:0.85rem;color:var(--clr-text-muted);font-weight:500;">
                      {p.autores || <span style="color:var(--clr-text-dim);">—</span>}
                    </td>
                    <td style="text-align:right;">
                      <div style="display:flex;gap:0.5rem;justify-content:flex-end;">
                        <button
                          class="btn btn--outline btn--sm"
                          style="border-radius:100px;padding:0.35rem 0.95rem;font-weight:700;"
                          onclick={`abrirModal(${JSON.stringify(p)})`}
                        >
                          Editar
                        </button>
                        <button
                          class="btn btn--danger btn--sm"
                          style="border-radius:100px;padding:0.35rem 0.95rem;font-weight:700;"
                          onclick={`eliminarProyecto(${p.id}, '${p.nombre.replace(/'/g, "\\'")}')`}
                        >
                          Eliminar
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      );
    })}

    {categorias.length === 0 && (
      <div class="alert alert--info">
        <span>ℹ️</span> Primero crea categorías antes de agregar proyectos.
        <a href="/admin/categorias" style="margin-left:0.5rem;font-weight:600;">Ir a Categorías →</a>
      </div>
    )}
  </div>

  <!-- Modal Proyecto -->
  <div class="modal-overlay" id="modal-overlay">
    <div class="modal" style="max-width:520px;">
      <h3 id="modal-title" style="margin-bottom:1.5rem;">Agregar Proyecto</h3>
      <form id="proyecto-form" method="POST">
        <input type="hidden" name="_id" id="campo-id" />
        <div style="display:grid;gap:1rem;">
          <div class="form-group">
            <label class="form-label" for="campo-nombre">Nombre del proyecto *</label>
            <input id="campo-nombre" class="form-input" type="text" name="nombre" required placeholder="Nombre del proyecto" />
          </div>
          <div class="form-group">
            <label class="form-label" for="campo-categoria">Categoría *</label>
            <select id="campo-categoria" class="form-input form-select" name="categoria_id" required>
              {categorias.filter(c => c.activa === true).map(cat => (
                <option value={cat.id}>{cat.nombre}</option>
              ))}
            </select>
          </div>
          <div class="form-group">
            <label class="form-label" for="campo-descripcion">Descripción</label>
            <textarea
              id="campo-descripcion"
              class="form-input"
              name="descripcion"
              placeholder="Descripción breve del proyecto..."
              rows={3}
              style="resize:vertical;"
            ></textarea>
          </div>
          <div class="form-group">
            <label class="form-label" for="campo-autores">Autores / Equipo</label>
            <input id="campo-autores" class="form-input" type="text" name="autores" placeholder="Ej: Juan, María, Carlos" />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:0.75rem;">
            <button type="button" class="btn btn--outline" style="border-radius:100px;font-weight:700;" onclick="cerrarModal()">Cancelar</button>
            <button type="submit" class="btn btn--primary" style="border-radius:100px;font-weight:700;box-shadow:0 4px 14px rgba(0, 89, 78, 0.25);" id="modal-submit-btn">Guardar</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  function abrirModal(proyecto?: any, categoriaId?: number) {
    const form = document.getElementById('proyecto-form') as HTMLFormElement;
    const title = document.getElementById('modal-title')!;
    const submitBtn = document.getElementById('modal-submit-btn')!;

    if (proyecto) {
      title.textContent = 'Editar Proyecto';
      submitBtn.textContent = 'Guardar cambios';
      form.action = `/api/admin/proyectos/${proyecto.id}?_method=PUT`;
      (document.getElementById('campo-id') as HTMLInputElement).value = proyecto.id;
      (document.getElementById('campo-nombre') as HTMLInputElement).value = proyecto.nombre;
      (document.getElementById('campo-categoria') as HTMLSelectElement).value = proyecto.categoria_id;
      (document.getElementById('campo-descripcion') as HTMLTextAreaElement).value = proyecto.descripcion || '';
      (document.getElementById('campo-autores') as HTMLInputElement).value = proyecto.autores || '';
    } else {
      title.textContent = 'Agregar Proyecto';
      submitBtn.textContent = 'Agregar proyecto';
      form.action = '/api/admin/proyectos';
      form.reset();
      if (categoriaId) {
        (document.getElementById('campo-categoria') as HTMLSelectElement).value = String(categoriaId);
      }
    }

    document.getElementById('modal-overlay')!.classList.add('active');
  }

  function cerrarModal() {
    document.getElementById('modal-overlay')!.classList.remove('active');
  }

  async function eliminarProyecto(id: number, nombre: string) {
    if (!confirm(`¿Eliminar el proyecto "${nombre}"? Esta acción no se puede deshacer.`)) return;
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = `/api/admin/proyectos/${id}?_method=DELETE`;
    document.body.appendChild(form);
    form.submit();
  }

  document.getElementById('modal-overlay')!.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) cerrarModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') cerrarModal();
  });

  (window as any).abrirModal = abrirModal;
  (window as any).cerrarModal = cerrarModal;
  (window as any).eliminarProyecto = eliminarProyecto;
</script>
