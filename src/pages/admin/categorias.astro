---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { obtenerCategorias } from '../../lib/db';

const categorias = obtenerCategorias();
const msg = Astro.url.searchParams.get('msg');
---

<AdminLayout title="Categorías" activePage="categorias">
  <div style="max-width:800px;">
    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;margin-bottom:2rem;">
      <div>
        <h1 style="font-size:1.8rem;margin-bottom:0.25rem;">Categorías</h1>
        <p>Gestiona las 3 categorías de proyectos para votación</p>
      </div>
      <button class="btn btn--primary" onclick="abrirModal()">+ Nueva categoría</button>
    </div>

    {msg === 'created' && <div class="alert alert--success mb-3"><span>✅</span> Categoría creada</div>}
    {msg === 'updated' && <div class="alert alert--success mb-3"><span>✅</span> Categoría actualizada</div>}
    {msg === 'deleted' && <div class="alert alert--success mb-3"><span>✅</span> Categoría eliminada</div>}

    <div class="table-wrapper">
      <table>
        <thead>
          <tr>
            <th>Orden</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Estado</th>
            <th style="text-align:right;">Acciones</th>
          </tr>
        </thead>
        <tbody>
          {categorias.map(cat => (
            <tr>
              <td style="color:var(--clr-text-dim);font-size:0.85rem;">{cat.orden}</td>
              <td style="font-weight:600;">{cat.nombre}</td>
              <td style="color:var(--clr-text-muted);font-size:0.85rem;max-width:250px;">
                {cat.descripcion || <span style="color:var(--clr-text-dim);">—</span>}
              </td>
              <td>
                <span class={`badge ${cat.activa ? 'badge--green' : 'badge--red'}`}>
                  {cat.activa ? 'Activa' : 'Inactiva'}
                </span>
              </td>
              <td style="text-align:right;">
                <div style="display:flex;gap:0.5rem;justify-content:flex-end;">
                  <button class="btn btn--outline btn--sm" onclick={`abrirModal(${JSON.stringify(cat)})`}>Editar</button>
                  <button class="btn btn--danger btn--sm" onclick={`eliminarCategoria(${cat.id}, '${cat.nombre.replace(/'/g, "\\'")}')`}>Eliminar</button>
                </div>
              </td>
            </tr>
          ))}
          {categorias.length === 0 && (
            <tr>
              <td colspan={5} style="text-align:center;color:var(--clr-text-dim);padding:2rem;">
                Sin categorías creadas. Agrega la primera.
              </td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modal -->
  <div class="modal-overlay" id="modal-overlay">
    <div class="modal">
      <h3 id="modal-title" style="margin-bottom:1.5rem;">Nueva Categoría</h3>
      <form id="cat-form" method="POST" action="/api/admin/categorias">
        <input type="hidden" name="_id" id="campo-id" />
        <div style="display:grid;gap:1rem;">
          <div class="form-group">
            <label class="form-label" for="campo-nombre">Nombre *</label>
            <input id="campo-nombre" class="form-input" type="text" name="nombre" required placeholder="Nombre de la categoría" />
          </div>
          <div class="form-group">
            <label class="form-label" for="campo-desc">Descripción</label>
            <input id="campo-desc" class="form-input" type="text" name="descripcion" placeholder="Descripción breve" />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
              <label class="form-label" for="campo-orden">Orden</label>
              <input id="campo-orden" class="form-input" type="number" name="orden" value="0" min="0" />
            </div>
            <div class="form-group">
              <label class="form-label" for="campo-activa">Estado</label>
              <select id="campo-activa" class="form-input form-select" name="activa">
                <option value="1">Activa</option>
                <option value="0">Inactiva</option>
              </select>
            </div>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-top:0.5rem;">
            <button type="button" class="btn btn--outline" onclick="cerrarModal()">Cancelar</button>
            <button type="submit" id="submit-btn" class="btn btn--primary">Guardar</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>

<script>
  function abrirModal(cat?: any) {
    const form = document.getElementById('cat-form') as HTMLFormElement;
    const title = document.getElementById('modal-title')!;
    const submitBtn = document.getElementById('submit-btn')!;

    if (cat) {
      title.textContent = 'Editar Categoría';
      submitBtn.textContent = 'Guardar cambios';
      form.action = `/api/admin/categorias/${cat.id}?_method=PUT`;
      (document.getElementById('campo-id') as HTMLInputElement).value = cat.id;
      (document.getElementById('campo-nombre') as HTMLInputElement).value = cat.nombre;
      (document.getElementById('campo-desc') as HTMLInputElement).value = cat.descripcion || '';
      (document.getElementById('campo-orden') as HTMLInputElement).value = cat.orden;
      (document.getElementById('campo-activa') as HTMLSelectElement).value = String(cat.activa);
    } else {
      title.textContent = 'Nueva Categoría';
      submitBtn.textContent = 'Crear categoría';
      form.action = '/api/admin/categorias';
      form.reset();
      (document.getElementById('campo-activa') as HTMLSelectElement).value = '1';
    }

    document.getElementById('modal-overlay')!.classList.add('active');
  }

  function cerrarModal() {
    document.getElementById('modal-overlay')!.classList.remove('active');
  }

  function eliminarCategoria(id: number, nombre: string) {
    if (!confirm(`¿Eliminar la categoría "${nombre}"? Esto también eliminará todos sus proyectos.`)) return;
    const form = document.createElement('form');
    form.method = 'POST';
    form.action = `/api/admin/categorias/${id}?_method=DELETE`;
    document.body.appendChild(form);
    form.submit();
  }

  document.getElementById('modal-overlay')!.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) cerrarModal();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') cerrarModal(); });

  (window as any).abrirModal = abrirModal;
  (window as any).cerrarModal = cerrarModal;
  (window as any).eliminarCategoria = eliminarCategoria;
</script>
