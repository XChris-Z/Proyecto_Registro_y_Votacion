---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { obtenerAsistentes, obtenerCategorias, obtenerProyectos, obtenerResultados } from '@lib/db';

const asistentes = await obtenerAsistentes();
const categorias = await obtenerCategorias();
const proyectos = await obtenerProyectos();
const resultados = await obtenerResultados();

const totalVotos = resultados.reduce((sum, r) => sum + r.total_votos, 0);
---

<AdminLayout title="Dashboard" activePage="dashboard">
  <div style="max-width:1150px;">
    <div style="margin-bottom:2rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;">
      <div>
        <h1 style="font-size:2rem;font-weight:800;margin-bottom:0.25rem;color:var(--clr-text);">Dashboard Unitrópico</h1>
        <p style="color:var(--clr-text-muted);">Estadísticas institucionales y participación en tiempo real del evento</p>
      </div>
      <a href="/admin/historial" class="btn btn--primary" style="padding:0.65rem 1.4rem;font-size:0.9rem;border-radius:100px;background:#00594E !important;color:#FFFFFF !important;border:2px solid #B5A160 !important;box-shadow:0 4px 14px rgba(0,89,78,0.25);font-weight:800;display:inline-flex;align-items:center;gap:0.55rem;text-decoration:none;">
        <span style="font-size:1.1rem;">📜</span>
        <span>Archivar / Cierre de Jornada</span>
      </a>
    </div>

    <!-- Hero Card — Total Participantes Destacado -->
    <div class="hero-participantes card mb-4 animate-fade-up">
      <div class="hero-participantes__content">
        <div class="hero-badge">⚡ EN VIVO — SISTEMA DE REGISTRO</div>
        <h2 class="hero-title">Número Total de Participantes Registrados</h2>
        <p class="hero-subtitle">Asistentes acreditados con documento y correo institucional de Unitrópico</p>
      </div>
      <div class="hero-participantes__counter">
        <div class="counter-number animated-counter" data-target={asistentes.length}>0</div>
        <div class="counter-label">Participantes</div>
      </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
      {[
        { label: 'Categorías activas', value: categorias.filter(c => c.activa === true).length, icon: '🏷️' },
        { label: 'Proyectos candidatos', value: proyectos.length, icon: '📁' },
        { label: 'Votos emitidos', value: totalVotos, icon: '🗳️' },
      ].map((stat, i) => (
        <div class="stat-card" style={`animation: fadeInUp 0.5s ease ${0.05 + i * 0.08}s both`}>
          <div class="stat-card__icon">{stat.icon}</div>
          <div class="stat-card__value animated-counter" data-target={stat.value}>0</div>
          <div class="stat-card__label">{stat.label}</div>
        </div>
      ))}
    </div>

    <!-- Resultados rápidos -->
    <div class="dashboard-results-grid">
      <div>
        <h2 style="font-size:1.2rem;margin-bottom:1.1rem;font-weight:800;color:var(--clr-text);">Resultados por Categoría</h2>
        {categorias.filter(c => c.activa).map(cat => {
          const catResultados = resultados.filter(r => r.categoria_id === cat.id).slice(0, 3);
          const maxVotos = Math.max(...catResultados.map(r => r.total_votos), 1);
          return (
            <div class="card" style="margin-bottom:1.25rem;position:relative;overflow:hidden;">
              <div style="position:absolute;top:0;left:0;right:0;height:3px;background:var(--gradient-primary);"></div>
              <h3 style="font-size:1rem;margin-bottom:1rem;font-weight:700;color:var(--clr-text);display:flex;align-items:center;gap:0.4rem;">
                <span>🏷️</span> {cat.nombre}
              </h3>
              {catResultados.length === 0 && <p style="font-size:0.82rem;color:var(--clr-text-dim);">Sin votos registrados aún</p>}
              {catResultados.map((r, i) => (
                <div style="margin-bottom:0.9rem;">
                  <div style="display:flex;justify-content:space-between;font-size:0.88rem;margin-bottom:0.35rem;">
                    <span style={i === 0 ? 'color:var(--clr-primary);font-weight:800;' : 'font-weight:600;color:var(--clr-text);'}>
                      {i === 0 ? '🏆 ' : ''}{r.proyecto_nombre}
                    </span>
                    <strong style={i === 0 ? 'color:var(--clr-primary);' : 'color:var(--clr-text-muted);'}>{r.total_votos} votos</strong>
                  </div>
                  <div class="progress-bar" style="height:8px;border-radius:100px;">
                    <div class="progress-bar__fill" style={`width:${(r.total_votos / maxVotos) * 100}%;background:linear-gradient(90deg, #00594E 0%, #B5A160 100%);`}></div>
                  </div>
                </div>
              ))}
            </div>
          );
        })}
      </div>

      <!-- Últimos registros -->
      <div>
        <h2 style="font-size:1.2rem;margin-bottom:1.1rem;font-weight:800;color:var(--clr-text);">Últimos Registros</h2>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>Nombre</th>
                <th>Dependencia</th>
                <th>Fecha</th>
              </tr>
            </thead>
            <tbody>
              {asistentes.slice(0, 8).map(a => (
                <tr>
                  <td style="font-weight:700;color:var(--clr-text);">{a.nombre}</td>
                  <td style="color:var(--clr-text-muted);font-size:0.85rem;font-weight:500;">{a.dependencia}</td>
                  <td style="color:var(--clr-text-dim);font-size:0.8rem;">
                    {new Date(a.fecha_registro).toLocaleDateString('es-CO')}
                  </td>
                </tr>
              ))}
              {asistentes.length === 0 && (
                <tr>
                  <td colspan={3} style="text-align:center;color:var(--clr-text-dim);padding:2rem;">Sin registros aún</td>
                </tr>
              )}
            </tbody>
          </table>
        </div>
        {asistentes.length > 8 && (
          <a href="/admin/asistentes" class="btn btn--primary" style="float:right;margin-top:0.85rem;padding:0.5rem 1.25rem;border-radius:100px;background:#00594E !important;color:#FFFFFF !important;border:1.5px solid #B5A160 !important;font-weight:700;text-decoration:none;">
            <span>Ver todos los {asistentes.length} asistentes →</span>
          </a>
        )}
      </div>
    </div>
  </div>
</AdminLayout>

<style>
  .hero-participantes {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1.75rem;
    background: linear-gradient(135deg, #00594E 0%, #003a33 100%);
    border: 2px solid #B5A160;
    padding: 2.25rem 2.75rem;
    border-radius: var(--radius-lg);
    box-shadow: 0 14px 40px rgba(0, 89, 78, 0.25);
    position: relative;
    overflow: hidden;
  }

  .hero-participantes::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -10%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(181, 161, 96, 0.25) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }

  .hero-badge {
    background: #B5A160;
    color: #041815;
    font-size: 0.76rem;
    font-weight: 800;
    padding: 0.38rem 0.95rem;
    border-radius: 100px;
    display: inline-block;
    margin-bottom: 0.85rem;
    letter-spacing: 0.05em;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }
  .hero-title {
    font-size: 1.65rem;
    font-weight: 800;
    color: #FFFFFF;
    margin-bottom: 0.4rem;
    line-height: 1.25;
  }
  .hero-subtitle {
    font-size: 0.94rem;
    color: rgba(255, 255, 255, 0.82);
    font-weight: 500;
  }
  .hero-participantes__counter {
    text-align: center;
    background: rgba(0, 0, 0, 0.35);
    padding: 1.4rem 2.2rem;
    border-radius: var(--radius-md);
    border: 1.5px solid #B5A160;
    min-width: 180px;
    box-shadow: inset 0 2px 12px rgba(0, 0, 0, 0.3), 0 4px 16px rgba(0, 0, 0, 0.2);
    position: relative;
    z-index: 1;
  }
  .counter-number {
    font-size: 3.5rem;
    font-weight: 900;
    color: #B5A160;
    line-height: 1;
    text-shadow: 0 0 25px rgba(181, 161, 96, 0.55);
  }
  .counter-label {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.4rem;
  }
  .mb-4 { margin-bottom: 1.75rem; }
</style>

<script>
  function animateCounters() {
    const counters = document.querySelectorAll('.animated-counter');

    counters.forEach(counter => {
      const target = parseInt(counter.getAttribute('data-target') || '0', 10);
      const duration = 1400; // 1.4 segundos
      const startTime = performance.now();

      function update(currentTime: number) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / duration, 1);
        // Ease out cubic
        const easeOut = 1 - Math.pow(1 - progress, 3);
        const current = Math.floor(easeOut * target);

        counter.textContent = String(current);

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          counter.textContent = String(target);
        }
      }

      requestAnimationFrame(update);
    });
  }

  document.addEventListener('astro:page-load', animateCounters);
</script>
