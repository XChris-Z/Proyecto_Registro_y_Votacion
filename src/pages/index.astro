---
import MainLayout from '../layouts/MainLayout.astro';
import { obtenerJornadaActual, obtenerEstadisticasEnVivo } from '@lib/db';

const error = Astro.url.searchParams.get('error');
const [jornadaActual, stats] = await Promise.all([
  obtenerJornadaActual(),
  obtenerEstadisticasEnVivo()
]);
const estaCerrada = jornadaActual.estado === 'CERRADA';
---

<MainLayout title="Registro de Asistencia">
  <section class="page-hero">
    <div class="container--narrow">
      <div class="page-hero__eyebrow animate-fade-up" style="animation-delay:0s;">
        <span>📋</span> Registro de Asistencia
      </div>
      <h1 class="page-hero__title animate-fade-up" style="animation-delay:0.1s;">
        {estaCerrada ? 'Jornada Finalizada' : '¡Únete al evento!'}
      </h1>
      <p class="page-hero__sub animate-fade-up" style="animation-delay:0.2s;">
        {estaCerrada
          ? 'El proceso de registro y votación se encuentra cerrado.'
          : 'Completa tu registro en menos de un minuto y asegura tu participación.'}
      </p>
    </div>
  </section>

  <section style="padding-bottom:4rem;">
    <div class="container--narrow">
      <div class="glass animate-fade-up" style="padding:2.5rem;animation-delay:0.3s;">

        {error === 'closed' && (
          <div class="alert alert--error mb-3">
            <span>🔒</span> La jornada electoral se encuentra cerrada en este momento.
          </div>
        )}
        {error === 'fields' && (
          <div class="alert alert--error mb-3">
            <span>⚠️</span> Todos los campos son obligatorios. Por favor compótalos.
          </div>
        )}
        {error === 'documento' && (
          <div class="alert alert--error mb-3">
            <span>⚠️</span> El número de documento solo debe contener dígitos.
          </div>
        )}
        {error === 'correo' && (
          <div class="alert alert--error mb-3">
            <span>⚠️</span> El correo electrónico no tiene un formato válido.
          </div>
        )}
        {error === 'telefono' && (
          <div class="alert alert--error mb-3">
            <span>⚠️</span> El número de teléfono debe tener entre 7 y 15 dígitos.
          </div>
        )}
        {error === 'duplicate' && (
          <div class="alert alert--error mb-3">
            <span>⚠️</span> Ya existe un registro con ese documento y correo. ¿Ya te registraste antes?
          </div>
        )}
        {error === 'server' && (
          <div class="alert alert--error mb-3">
            <span>⚠️</span> Error al guardar. Verifica tu conexión o intenta de nuevo.
          </div>
        )}

        {estaCerrada ? (
          <div style="text-align:center;padding:1.5rem 0;">
            <div style="font-size:3.5rem;margin-bottom:1rem;">🔒</div>
            <span style="background:var(--clr-accent);color:#041815;font-weight:800;font-size:0.78rem;padding:0.4rem 1rem;border-radius:999px;">
              JORNADA OFICIALMENTE CERRADA
            </span>
            <h2 style="font-size:1.8rem;margin-top:1.2rem;color:var(--clr-text);font-weight:800;">
              {jornadaActual.nombre}
            </h2>
            <p style="color:var(--clr-text-muted);font-size:1.02rem;max-width:520px;margin:1rem auto 2rem;line-height:1.6;">
              El proceso de registro de asistencia y votación para esta jornada ha concluido oficialmente. Agradecemos tu interés y participación.
            </p>
            <div style="border-top:1px solid var(--clr-border);padding-top:1.5rem;color:var(--clr-text-dim);font-size:0.85rem;">
              Unitrópico — Institución Universitaria del Trópico Colombiano
            </div>
          </div>
        ) : (
          <form id="registro-form" method="POST" action="/api/registro" novalidate>
            <div style="display:grid;gap:1.25rem;">

              <!-- Nombre -->
              <div class="form-group">
                <label class="form-label" for="nombre">Nombre completo</label>
                <input
                  id="nombre"
                  class="form-input"
                  type="text"
                  name="nombre"
                  placeholder="Ej: María García López"
                  required
                  minlength="3"
                  autocomplete="name"
                />
              </div>

              <!-- Documento -->
              <div class="form-group">
                <label class="form-label" for="documento">Número de documento</label>
                <input
                  id="documento"
                  class="form-input"
                  type="text"
                  name="documento"
                  placeholder="Ej: 1234567890"
                  required
                  pattern="[0-9]+"
                  inputmode="numeric"
                />
                <span class="form-hint">Solo números, sin puntos ni guiones</span>
              </div>

              <!-- Dependencia -->
              <div class="form-group">
                <label class="form-label" for="dependencia">Dependencia / Institución</label>
                <input
                  id="dependencia"
                  class="form-input"
                  type="text"
                  name="dependencia"
                  placeholder="Ej: Universidad Nacional, Facultad de Ingeniería..."
                  required
                  minlength="2"
                />
              </div>

              <!-- Correo -->
              <div class="form-group">
                <label class="form-label" for="correo">Correo electrónico</label>
                <input
                  id="correo"
                  class="form-input"
                  type="email"
                  name="correo"
                  placeholder="Ej: maria@universidad.edu.co"
                  required
                  autocomplete="email"
                />
              </div>

              <!-- Teléfono -->
              <div class="form-group">
                <label class="form-label" for="telefono">Número de teléfono</label>
                <input
                  id="telefono"
                  class="form-input"
                  type="tel"
                  name="telefono"
                  placeholder="Ej: 3001234567"
                  required
                  pattern="[0-9]{7,15}"
                  inputmode="numeric"
                  autocomplete="tel"
                />
                <span class="form-hint">Solo números, sin espacios ni guiones (7 a 15 dígitos)</span>
              </div>

              <!-- Botón -->
              <div style="margin-top:0.5rem;">
                <button id="submit-btn" type="submit" class="btn btn--primary btn--lg btn--full">
                  <span id="btn-text">Registrarme ahora</span>
                  <span id="btn-spinner" class="spinner hidden"></span>
                </button>
              </div>

              <p class="text-center" style="font-size:0.8rem;color:var(--clr-text-dim);">
                🔒 Tu información es confidencial y solo se usa para el evento
              </p>

            </div>
          </form>
        )}
      </div>

      <!-- Sección de Estadísticas en Tiempo Real -->
      <div class="live-stats-section animate-fade-up" style="animation-delay:0.4s;">
        <div class="live-stats-header">
          <div class="live-badge">
            <span class="live-badge__dot"></span>
            <span>⚡ En Vivo — Participación</span>
          </div>
          <span class="live-stats-header__title">Actualización automática al instante</span>
        </div>

        <div class="live-stats-grid">
          <!-- Personas Registradas -->
          <div class="live-stat-box">
            <div class="live-stat-box__icon">👥</div>
            <div class="live-stat-box__content">
              <div id="live-asistentes" class="live-stat-box__value">{stats.asistentes}</div>
              <div class="live-stat-box__label">Personas Registradas</div>
              <div class="live-stat-box__sub">Estudiantes, docentes y personal institucional</div>
            </div>
          </div>

          <!-- Total Votos Emitidos -->
          <div class="live-stat-box">
            <div class="live-stat-box__icon">🗳️</div>
            <div class="live-stat-box__content">
              <div id="live-votos" class="live-stat-box__value">{stats.votos}</div>
              <div class="live-stat-box__label">Votos Emitidos</div>
              <div class="live-stat-box__sub">Participación activa en prototipos y proyectos</div>
            </div>
          </div>
        </div>

        <div class="live-stats-footer">
          <span class="live-stats-footer__spinner"></span>
          <span>Sincronizando con el servidor institucional en tiempo real</span>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const form = document.getElementById('registro-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text') as HTMLSpanElement;
  const btnSpinner = document.getElementById('btn-spinner') as HTMLSpanElement;

  // Validación en tiempo real
  const inputs = form.querySelectorAll<HTMLInputElement>('input[required]');
  inputs.forEach(input => {
    input.addEventListener('blur', () => validateInput(input));
    input.addEventListener('input', () => {
      if (input.classList.contains('error')) validateInput(input);
    });
  });

  function validateInput(input: HTMLInputElement) {
    const group = input.closest('.form-group');
    const existingError = group?.querySelector('.form-error');
    existingError?.remove();

    if (!input.validity.valid) {
      input.style.borderColor = 'var(--clr-error)';
      const errorEl = document.createElement('span');
      errorEl.className = 'form-error';
      errorEl.textContent = getErrorMsg(input);
      input.classList.add('error');
      group?.appendChild(errorEl);
    } else {
      input.style.borderColor = '';
      input.classList.remove('error');
    }
  }

  function getErrorMsg(input: HTMLInputElement): string {
    if (input.validity.valueMissing) return 'Este campo es obligatorio';
    if (input.validity.typeMismatch) return 'Ingresa un correo válido';
    if (input.validity.patternMismatch) return 'Solo se permiten números';
    if (input.validity.tooShort) return `Mínimo ${input.minLength} caracteres`;
    return 'Campo inválido';
  }

  form.addEventListener('submit', (e) => {
    let valid = true;
    inputs.forEach(input => {
      if (!input.validity.valid) {
        validateInput(input);
        valid = false;
      }
    });
    if (!valid) {
      e.preventDefault();
      return;
    }
    btnText.textContent = 'Registrando...';
    btnSpinner.classList.remove('hidden');
    submitBtn.disabled = true;
  });

  // Sincronización en tiempo real con /api/stats
  function updateLiveStats() {
    fetch('/api/stats')
      .then(res => res.json())
      .then(data => {
        if (data && data.success) {
          animateCountChange('live-asistentes', data.asistentes);
          animateCountChange('live-votos', data.votos);
        }
      })
      .catch(() => { /* Falla silenciosa si no hay red */ });
  }

  function animateCountChange(elementId: string, newValue: number) {
    const el = document.getElementById(elementId);
    if (!el) return;
    const currentValue = parseInt(el.textContent || '0', 10);
    if (currentValue !== newValue) {
      el.classList.add('updated');
      el.textContent = newValue.toString();
      setTimeout(() => el.classList.remove('updated'), 300);
    }
  }

  // Polling cada 4 segundos
  setInterval(updateLiveStats, 4000);
</script>
