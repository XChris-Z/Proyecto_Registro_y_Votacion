---
import MainLayout from '../../layouts/MainLayout.astro';

const nombre = Astro.cookies.get('votacion_nombre')?.value || 'Participante';
---

<MainLayout title="¡Gracias por Votar!">
  <section style="min-height:80vh;display:flex;align-items:center;justify-content:center;padding:2rem 0;">
    <div class="container--narrow" style="text-align:center;">

      <!-- Confetti-like decorations -->
      <div style="position:relative;margin-bottom:2rem;">
        <div style="
          width:100px;height:100px;
          background:var(--gradient-accent);
          border-radius:50%;
          display:flex;align-items:center;justify-content:center;
          font-size:3rem;
          margin:0 auto;
          box-shadow:0 0 80px rgba(245,197,24,0.4);
          animation:fadeInUp 0.5s ease, spin-slow 8s linear infinite;
        ">🏆</div>
        <div style="position:absolute;top:-10px;left:50%;transform:translateX(-120px);font-size:1.5rem;animation:float1 3s ease-in-out infinite;">⭐</div>
        <div style="position:absolute;top:10px;right:50%;transform:translateX(120px);font-size:1.2rem;animation:float2 3.5s ease-in-out infinite;">✨</div>
        <div style="position:absolute;bottom:-5px;left:50%;transform:translateX(-80px);font-size:1rem;animation:float1 4s ease-in-out infinite 0.5s;">🌟</div>
      </div>

      <h1 class="animate-fade-up" style="
        animation-delay:0.1s;
        background:var(--gradient-accent);
        -webkit-background-clip:text;-webkit-text-fill-color:transparent;
        background-clip:text;
      ">¡Gracias por votar!</h1>

      <p class="animate-fade-up" style="animation-delay:0.2s;font-size:1.1rem;margin:1rem 0 0.5rem;">
        <strong style="color:var(--clr-text);">{nombre}</strong>, tu participación es muy importante.
      </p>
      <p class="animate-fade-up" style="animation-delay:0.25s;">
        Tus votos han sido registrados exitosamente en las 3 categorías.
      </p>

      <div class="glass animate-fade-up" style="animation-delay:0.35s;padding:1.5rem;margin:2rem 0;text-align:left;">
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;text-align:center;">
          {[
            { icon: '💡', label: 'Tecnología' },
            { icon: '🌿', label: 'Ciencia' },
            { icon: '🌍', label: 'Social' },
          ].map(cat => (
            <div>
              <div style="font-size:1.8rem;">{cat.icon}</div>
              <div style="font-size:0.8rem;color:var(--clr-text-muted);margin-top:0.3rem;">{cat.label}</div>
              <div style="color:var(--clr-success);font-weight:700;font-size:0.9rem;margin-top:0.2rem;">✓ Votado</div>
            </div>
          ))}
        </div>
      </div>

      <div class="animate-fade-up" style="animation-delay:0.45s;">
        <a href="/" class="btn btn--outline btn--lg">
          ← Volver al inicio
        </a>
      </div>

    </div>
  </section>
</MainLayout>

<style>
@keyframes float1 {
  0%, 100% { transform: translateX(-120px) translateY(0); }
  50% { transform: translateX(-120px) translateY(-12px); }
}
@keyframes float2 {
  0%, 100% { transform: translateX(120px) translateY(0); }
  50% { transform: translateX(120px) translateY(-8px); }
}
@keyframes spin-slow {
  to { transform: rotate(360deg); }
}
</style>
