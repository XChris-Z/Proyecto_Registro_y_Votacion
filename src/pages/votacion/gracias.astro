---
import MainLayout from '../../layouts/MainLayout.astro';
import { obtenerCategorias } from '@lib/db';

let nombreRaw = Astro.cookies.get('votacion_nombre')?.value || 'Participante';
if (nombreRaw.trim().toLowerCase().startsWith('has ') || nombreRaw.trim().toLowerCase() === 'has') {
  nombreRaw = 'Participante';
}
const primerNombre = nombreRaw.trim().split(' ')[0] || 'Participante';
const nombreDisplay = primerNombre.charAt(0).toUpperCase() + primerNombre.slice(1).toLowerCase();

const categorias = (await obtenerCategorias()).filter(c => c.activa === true);
---

<MainLayout title="¡Gracias por Votar!">
  <section style="min-height:80vh;display:flex;align-items:center;justify-content:center;padding:3rem 0;">
    <div class="container--narrow" style="text-align:center;">

      <!-- Confetti-like decorations -->
      <div style="position:relative;margin-bottom:2.5rem;">
        <div style="
          width:110px;height:110px;
          background:var(--gradient-accent);
          border-radius:50%;
          display:flex;align-items:center;justify-content:center;
          font-size:3.5rem;
          margin:0 auto;
          box-shadow:0 0 80px rgba(181,161,96,0.45);
          animation:fadeInUp 0.5s ease, spin-slow 12s linear infinite;
          border: 3px solid #FFFFFF;
        ">🏆</div>
        <div style="position:absolute;top:-10px;left:50%;transform:translateX(-130px);font-size:1.8rem;animation:float1 3s ease-in-out infinite;">⭐</div>
        <div style="position:absolute;top:15px;right:50%;transform:translateX(130px);font-size:1.5rem;animation:float2 3.5s ease-in-out infinite;">✨</div>
        <div style="position:absolute;bottom:-5px;left:50%;transform:translateX(-90px);font-size:1.2rem;animation:float1 4s ease-in-out infinite 0.5s;">🌟</div>
      </div>

      <div class="page-hero__eyebrow animate-fade-up" style="justify-content:center;margin-bottom:1rem;">
        <span>🎉</span> ¡Votación completada exitosamente!
      </div>

      <h1 class="animate-fade-up" style="
        animation-delay:0.1s;
        color: var(--clr-primary);
        font-weight: 800;
      ">¡Gracias por tu voto!</h1>

      <p class="animate-fade-up" style="animation-delay:0.2s;font-size:1.15rem;margin:1rem auto 0.5rem;max-width:520px;">
        <strong style="color:var(--clr-text);">{nombreDisplay}</strong>, tu participación es un aporte fundamental para el desarrollo y reconocimiento de los proyectos en el evento.
      </p>
      <p class="animate-fade-up" style="animation-delay:0.25s;color:var(--clr-text-muted);font-size:0.98rem;">
        Tus selecciones han sido registradas y encriptadas en {categorias.length > 0 ? `las ${categorias.length} categorías configuradas` : 'la votación'}.
      </p>

      <div class="glass animate-fade-up" style="animation-delay:0.35s;padding:1.8rem;margin:2.5rem 0;text-align:left;border-radius:20px;border:1.5px solid var(--clr-border);box-shadow:var(--shadow-md);">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.2rem;padding-bottom:0.8rem;border-bottom:1px solid var(--clr-border);">
          <span style="font-size:0.88rem;font-weight:700;color:var(--clr-text);">Resumen de categorías oficiales</span>
          <span class="badge badge--green" style="padding:0.3rem 0.8rem;border-radius:999px;font-size:0.75rem;font-weight:700;">✓ Voto Registrado</span>
        </div>
        <div style={`display:grid;grid-template-columns:repeat(${Math.min(Math.max(categorias.length, 1), 4)},1fr);gap:1.2rem;text-align:center;`}>
          {categorias.map(cat => (
            <div style="background:rgba(0,0,0,0.02);padding:1rem 0.5rem;border-radius:14px;border:1px solid rgba(0,0,0,0.05);">
              <div style="font-size:2rem;margin-bottom:0.3rem;">🗳️</div>
              <div style="font-size:0.9rem;color:var(--clr-text);font-weight:700;line-height:1.3;">{cat.nombre}</div>
              <div style="color:var(--clr-success);font-weight:800;font-size:0.82rem;margin-top:0.4rem;display:flex;align-items:center;justify-content:center;gap:0.25rem;">
                <span>✓</span> Votado
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="animate-fade-up" style="animation-delay:0.45s;display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/votacion/votar" class="btn btn--outline" style="border-radius:100px;font-weight:600;">
          ← Revisar mis votos
        </a>
        <a href="/" class="btn btn--primary" style="border-radius:100px;font-weight:700;box-shadow:0 4px 15px rgba(0,89,78,0.25);">
          🏠 Volver al inicio →
        </a>
      </div>

    </div>
  </section>
</MainLayout>

<style>
@keyframes float1 {
  0%, 100% { transform: translateX(-120px) translateY(0); }
  50% { transform: translateX(-120px) translateY(-12px); }
}
@keyframes float2 {
  0%, 100% { transform: translateX(120px) translateY(0); }
  50% { transform: translateX(120px) translateY(-8px); }
}
@keyframes spin-slow {
  to { transform: rotate(360deg); }
}
</style>
