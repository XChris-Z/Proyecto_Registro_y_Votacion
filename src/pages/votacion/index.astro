---
import MainLayout from '../../layouts/MainLayout.astro';
import { obtenerJornadaActual } from '@lib/db';

const error = Astro.url.searchParams.get('error');
const jornadaActual = await obtenerJornadaActual();
const estaCerrada = jornadaActual.estado === 'CERRADA';

const errorMessages: Record<string, string> = {
  notfound: 'No encontramos un registro con ese documento o correo. ¿Ya te registraste?',
  empty: 'Por favor ingresa tu documento o correo.',
  closed: 'La jornada de votación se encuentra oficialmente cerrada.'
};
---

<MainLayout title="Acceder para Votar">
  <section style="min-height:80vh;display:flex;align-items:center;justify-content:center;padding:2rem 0;">
    <div class="container--narrow">
      <div style="text-align:center;margin-bottom:2.5rem;">
        <div class="page-hero__eyebrow animate-fade-up" style="justify-content:center;">
          <span>🗳️</span> Sistema de Votación
        </div>
        <h1 class="animate-fade-up" style="
          animation-delay:0.1s;
          color: var(--clr-primary);
          margin-top:1rem;
        ">{estaCerrada ? 'Votación Cerrada' : 'Ingresa para votar'}</h1>
        <p class="animate-fade-up" style="animation-delay:0.2s;margin-top:0.75rem;font-size:1rem;">
          {estaCerrada
            ? 'La sesión electoral ha finalizado.'
            : 'Usa el mismo correo o número de documento con el que te registraste.'}
        </p>
      </div>

      <div class="glass animate-fade-up" style="padding:2.5rem;animation-delay:0.3s;">

        {error && errorMessages[error] && (
          <div class="alert alert--error mb-3">
            <span>⚠️</span> {errorMessages[error]}
            {error === 'notfound' && (
              <a href="/" style="margin-left:auto;font-size:0.85rem;white-space:nowrap;">Ir a registrarme →</a>
            )}
          </div>
        )}

        {estaCerrada ? (
          <div style="text-align:center;padding:1.5rem 0;">
            <div style="font-size:3.5rem;margin-bottom:1rem;">🔒</div>
            <span style="background:var(--clr-accent);color:#041815;font-weight:800;font-size:0.78rem;padding:0.4rem 1rem;border-radius:999px;">
              JORNADA OFICIALMENTE CERRADA
            </span>
            <h2 style="font-size:1.8rem;margin-top:1.2rem;color:var(--clr-text);font-weight:800;">
              {jornadaActual.nombre}
            </h2>
            <p style="color:var(--clr-text-muted);font-size:1.02rem;max-width:520px;margin:1rem auto 2rem;line-height:1.6;">
              El período de votación ha concluido y ya no se aceptan más votos. Agradecemos tu participación.
            </p>
            <div style="border-top:1px solid var(--clr-border);padding-top:1.5rem;color:var(--clr-text-dim);font-size:0.85rem;">
              Unitrópico — Institución Universitaria del Trópico Colombiano
            </div>
          </div>
        ) : (
          <form method="POST" action="/api/votar/login" id="login-form">
            <div style="display:grid;gap:1.25rem;">
              <div class="form-group">
                <label class="form-label" for="identificador">Documento o Correo electrónico</label>
                <input
                id="identificador"
                class="form-input"
                type="text"
                name="identificador"
                placeholder="Ej: 1234567890  o  tu@correo.com"
                required
                autocomplete="off"
                style="font-size:1rem;padding:1rem 1.25rem;"
              />
              <span class="form-hint">Ingresa cualquiera de los dos</span>
            </div>

            <button id="acceder-btn" type="submit" class="btn btn--primary btn--lg btn--full">
              <span>Acceder a votar →</span>
            </button>
          </div>
        </form>
        )}

        <div style="margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--clr-border);text-align:center;">
          <p style="font-size:0.85rem;color:var(--clr-text-dim);">
            ¿Aún no estás registrado?
            <a href="/" style="color:var(--clr-primary-light);font-weight:600;">Regístrate aquí →</a>
          </p>
        </div>

      </div>

      <!-- Info de votación -->
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:2rem;">
        {[
          { icon: '🏷️', title: '3 categorías', desc: 'Un voto por cada una' },
          { icon: '🔒', title: 'Voto definitivo', desc: 'No se puede cambiar' },
          { icon: '🏆', title: 'Resultados', desc: 'En tiempo real' },
        ].map(item => (
          <div class="card text-center" style="padding:1.25rem;">
            <div style="font-size:1.8rem;margin-bottom:0.5rem;">{item.icon}</div>
            <div style="font-weight:700;font-size:0.9rem;margin-bottom:0.25rem;">{item.title}</div>
            <div style="font-size:0.8rem;color:var(--clr-text-muted);">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>

<script>
  const form = document.getElementById('login-form') as HTMLFormElement;
  const btn = document.getElementById('acceder-btn') as HTMLButtonElement;
  form.addEventListener('submit', () => {
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner"></span> Buscando...';
  });
</script>
