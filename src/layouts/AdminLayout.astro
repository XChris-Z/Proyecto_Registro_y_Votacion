---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  activePage?: string;
}

import { obtenerJornadaActual } from '../lib/db';

const { title, activePage = '' } = Astro.props;
const jornadaActual = await obtenerJornadaActual();
const siteName = jornadaActual.nombre || 'Votación EXIS 9.ª edición';
const highlightedSiteName = siteName.replace(/EXIS/g, '<span class="text-highlight-exis">EXIS</span>');

const exitoParam = Astro.url.searchParams.get('exito');
const errorParam = Astro.url.searchParams.get('error');

const navItems = [
  { href: '/admin/dashboard', icon: '📊', label: 'Dashboard', id: 'dashboard' },
  { href: '/admin/proyectos', icon: '📁', label: 'Proyectos', id: 'proyectos' },
  { href: '/admin/categorias', icon: '🏷️', label: 'Categorías', id: 'categorias' },
  { href: '/admin/asistentes', icon: '👥', label: 'Asistentes', id: 'asistentes' },
  { href: '/admin/resultados', icon: '🏆', label: 'Resultados', id: 'resultados' },
  { href: '/admin/historial', icon: '📜', label: 'Historial / Cierre', id: 'historial' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <title>{title} — Admin {siteName}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  </head>
  <body class="admin-body" style="display:flex;flex-direction:column;min-height:100vh;">
    <!-- Orbes de fondo animados -->
    <div class="admin-bg-orbs" aria-hidden="true">
      <div class="orb orb--1"></div>
      <div class="orb orb--2"></div>
      <div class="orb orb--3"></div>
    </div>

    <div class="admin-layout" style="flex:1;">
      <aside class="admin-sidebar">
        <div class="admin-sidebar__logo">
          <a href="/" class="site-logo" style="color:var(--clr-text);display:flex;align-items:center;gap:0.6rem;text-decoration:none;">
            <img src="/logo.png" alt="Logo Unitrópico" style="height:2.1rem;width:auto;" />
            <div>
              <span class="admin-sidebar__logo-text" style="font-weight:800;font-size:1.2rem;display:block;" set:html={highlightedSiteName}></span>
              <p class="admin-sidebar__logo-text" style="font-size:0.75rem;color:var(--clr-text-muted);margin:0;">Panel Admin Unitrópico</p>
            </div>
          </a>
          
          <!-- Botón Colapsar para Escritorio -->
          <button
            type="button"
            class="btn-desktop-toggle hide-mobile"
            title="Colapsar o expandir menú lateral"
            onclick="toggleSidebarDesktop()"
            style="background:rgba(181,161,96,0.25);border:1.5px solid #B5A160;border-radius:8px;padding:0.45rem 0.65rem;color:#FFFFFF;cursor:pointer;font-weight:800;box-shadow:0 2px 8px rgba(0,0,0,0.2);transition:all 0.2s ease;"
          >
            <span id="desktop-toggle-icon">◀</span>
          </button>

          <!-- Botón Hamburguesa Desplegable para Móvil -->
          <button
            type="button"
            class="btn-mobile-hamburger hide-desktop"
            title="Menú del Administrador"
            onclick="toggleSidebarMobile()"
            style="background:rgba(181,161,96,0.25);border:1.5px solid #B5A160;border-radius:8px;padding:0.45rem 0.85rem;color:#FFFFFF;font-weight:800;cursor:pointer;gap:0.45rem;box-shadow:0 2px 8px rgba(0,0,0,0.2);"
          >
            <span id="mobile-hamburger-icon" style="font-size:1.1rem;">☰</span>
            <span style="font-size:0.85rem;">Menú</span>
          </button>
        </div>

        <div class="admin-sidebar__nav-wrapper" id="mobile-nav-wrapper">
          <nav class="admin-sidebar__nav">
            {navItems.map((item, i) => (
              <a
                href={item.href}
                class={`admin-nav__item ${activePage === item.id ? 'active' : ''}`}
                style={`animation-delay: ${i * 0.07}s`}
                title={item.label}
              >
                <span class="admin-nav__icon">{item.icon}</span>
                <span class="admin-nav__label">{item.label}</span>
                {activePage === item.id && <span class="admin-nav__indicator"></span>}
              </a>
            ))}
          </nav>
          <div class="admin-sidebar__footer" style="margin-top:auto;padding:1.5rem;">
            <form method="POST" action="/api/admin/logout" id="logout-form" style="width:100%;">
              <button type="submit" class="btn btn--logout btn--full" id="logout-btn" title="Cerrar sesión">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                  <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                  <polyline points="16 17 21 12 16 7"/>
                  <line x1="21" y1="12" x2="9" y2="12"/>
                </svg>
                <span class="admin-sidebar__footer-text">Cerrar sesión</span>
              </button>
            </form>
          </div>
        </div>
      </aside>

      <main class="admin-main" id="admin-main-content">
        <!-- Topbar Institucional -->
        <header class="admin-topbar">
          <div class="admin-topbar__left">
            <div class="admin-topbar__badge">
              <span class="pulse-dot"></span>
              <span>SISTEMA INSTITUCIONAL EN VIVO</span>
            </div>
            <h2 class="admin-topbar__title">{title}</h2>
          </div>
          <div class="admin-topbar__right">
            <button
              type="button"
              class="admin-nav-btn"
              title="Cambiar contraseña de seguridad del administrador"
              onclick="abrirModalPassword()"
              style="border-radius:100px;border:1.5px solid var(--clr-accent);background:rgba(181, 161, 96, 0.18);color:#FFFFFF;font-weight:700;cursor:pointer;"
            >
              <span>🔒</span>
              <span class="admin-nav-btn__label">Contraseña</span>
            </button>
            <div class="admin-topbar__divider"></div>
            <div style="display:flex;align-items:center;gap:0.5rem;">
              <span style="font-size:0.82rem;font-weight:700;color:rgba(255,255,255,0.85);" class="hide-mobile">Tema:</span>
              <ThemeToggle />
            </div>
          </div>
        </header>

        <div class="admin-page-enter" style="flex:1;padding:1.5rem 2.25rem 3.5rem;">
          {exitoParam === 'password_changed' && (
            <div class="alert alert--success mb-4" style="font-size:0.95rem;padding:1rem 1.35rem;box-shadow:var(--shadow-sm);">
              <span style="font-size:1.3rem;">✅</span>
              <div>
                <strong>¡Contraseña actualizada correctamente!</strong> Tus nuevas credenciales de administrador están activas.
              </div>
            </div>
          )}
          {errorParam === 'pass_old_wrong' && (
            <div class="alert alert--error mb-4" style="font-size:0.95rem;padding:1rem 1.35rem;">
              <span style="font-size:1.3rem;">⚠️</span>
              <div>
                <strong>Error al cambiar contraseña:</strong> La contraseña actual ingresada es incorrecta.
              </div>
            </div>
          )}
          {errorParam === 'pass_mismatch' && (
            <div class="alert alert--error mb-4" style="font-size:0.95rem;padding:1rem 1.35rem;">
              <span style="font-size:1.3rem;">⚠️</span>
              <div>
                <strong>Error al cambiar contraseña:</strong> La nueva contraseña y su confirmación no coinciden.
              </div>
            </div>
          )}
          {errorParam === 'pass_short' && (
            <div class="alert alert--error mb-4" style="font-size:0.95rem;padding:1rem 1.35rem;">
              <span style="font-size:1.3rem;">⚠️</span>
              <div>
                <strong>Error al cambiar contraseña:</strong> La nueva contraseña debe tener al menos 6 caracteres.
              </div>
            </div>
          )}
          {errorParam === 'pass_empty' && (
            <div class="alert alert--error mb-4" style="font-size:0.95rem;padding:1rem 1.35rem;">
              <span style="font-size:1.3rem;">⚠️</span>
              <div>
                <strong>Error al cambiar contraseña:</strong> Todos los campos del formulario son obligatorios.
              </div>
            </div>
          )}

          <slot />
        </div>

        <!-- Pie de página integrado en la columna principal -->
        <div style="width:100%;flex-shrink:0;margin-top:auto;">
          <Footer />
        </div>
      </main>
    </div>

    <!-- Modal Seguro de Cambio de Contraseña -->
    <div class="modal-overlay" id="modal-password-overlay" onclick="cerrarModalPassword(event)">
      <div class="modal card" style="max-width:460px;width:95%;border:2px solid #B5A160;background:var(--clr-surface);padding:2rem;" onclick="event.stopPropagation()">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;border-bottom:1px solid var(--clr-border);padding-bottom:1rem;">
          <h3 style="font-size:1.2rem;font-weight:800;color:var(--clr-text);margin:0;display:flex;align-items:center;gap:0.5rem;">
            <span>🔒</span> Cambiar Contraseña Admin
          </h3>
          <button type="button" onclick="cerrarModalPassword()" style="background:none;border:none;font-size:1.5rem;color:var(--clr-text-muted);cursor:pointer;">✕</button>
        </div>

        <form method="POST" action="/api/admin/cambiar-password" onsubmit="return validarFormularioPassword()">
          <input type="hidden" name="redirect_url" id="password-redirect-url" value="/admin/dashboard" />

          <div class="form-group mb-3">
            <label class="form-label" for="password_actual">Contraseña Actual <span style="color:var(--clr-error);">*</span></label>
            <input
              id="password_actual"
              name="password_actual"
              class="form-input"
              type="password"
              placeholder="Ingresa tu contraseña actual"
              required
              style="width:100%;border-radius:100px;padding:0.75rem 1.25rem;"
            />
          </div>

          <div class="form-group mb-3">
            <label class="form-label" for="password_nueva">Nueva Contraseña <span style="color:var(--clr-error);">*</span></label>
            <input
              id="password_nueva"
              name="password_nueva"
              class="form-input"
              type="password"
              placeholder="Mínimo 6 caracteres"
              required
              minlength="6"
              style="width:100%;border-radius:100px;padding:0.75rem 1.25rem;"
            />
            <span class="form-hint">Debe tener al menos 6 caracteres</span>
          </div>

          <div class="form-group mb-4">
            <label class="form-label" for="password_confirmacion">Confirmar Nueva Contraseña <span style="color:var(--clr-error);">*</span></label>
            <input
              id="password_confirmacion"
              name="password_confirmacion"
              class="form-input"
              type="password"
              placeholder="Repite la nueva contraseña"
              required
              minlength="6"
              style="width:100%;border-radius:100px;padding:0.75rem 1.25rem;"
            />
            <div id="password-error-msg" style="color:var(--clr-error);font-size:0.82rem;font-weight:700;margin-top:0.4rem;display:none;"></div>
          </div>

          <div style="display:flex;gap:0.85rem;justify-content:flex-end;">
            <button type="button" class="btn btn--outline" onclick="cerrarModalPassword()" style="border-radius:100px;padding:0.65rem 1.3rem;font-weight:700;">Cancelar</button>
            <button type="submit" class="btn btn--primary" style="border-radius:100px;padding:0.65rem 1.5rem;font-weight:800;background:var(--clr-primary);border-color:var(--clr-accent);">Guardar Cambios</button>
          </div>
        </form>
      </div>
    </div>

    <!-- Overlay de bloqueo mientras redirige (evita flash de contenido si la sesión expiró) -->
    <div id="session-guard-overlay" style="display:none;position:fixed;inset:0;background:var(--clr-bg);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:1rem;">
      <div class="spinner" style="width:32px;height:32px;"></div>
      <p style="color:var(--clr-text-muted);font-size:0.9rem;">Verificando sesión...</p>
    </div>
  </body>
</html>

<style>
/* ── Orbes de fondo ──────────────────────────────────── */
.admin-bg-orbs {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.07;
}

.admin-bg-orbs {
  display: none !important;
}

.orb--1 {
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, #00594E, transparent 70%);
  top: -200px;
  left: -100px;
  animation: orbFloat1 18s ease-in-out infinite;
}

.orb--2 {
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, #00594E, transparent 70%);
  bottom: -150px;
  right: -100px;
  animation: orbFloat2 22s ease-in-out infinite;
}

.orb--3 {
  width: 350px;
  height: 350px;
  background: radial-gradient(circle, #B5A160, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: orbFloat3 15s ease-in-out infinite;
  opacity: 0.04;
}

@keyframes orbFloat1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(60px, 40px) scale(1.08); }
  66% { transform: translate(-30px, 70px) scale(0.95); }
}

@keyframes orbFloat2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-80px, -50px) scale(1.12); }
}

@keyframes orbFloat3 {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.04; }
  50% { transform: translate(-50%, -50%) scale(1.3); opacity: 0.07; }
}

/* ── Admin body ──────────────────────────────────────── */
.admin-body {
  position: relative;
}

/* ── Sidebar enhancements ────────────────────────────── */
.admin-sidebar {
  position: relative;
  z-index: 1;
}

.admin-sidebar__nav {
  display: flex;
  flex-direction: column;
  padding: 0.5rem 0;
}

.admin-nav__item {
  position: relative;
  overflow: hidden;
  animation: slideInLeft 0.4s ease both;
}

@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(-16px); }
  to   { opacity: 1; transform: translateX(0); }
}

.admin-nav__icon {
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: inline-block;
}

.admin-nav__item:hover .admin-nav__icon {
  transform: scale(1.2) rotate(-5deg);
}

/* Shimmer hover effect on nav items */
.admin-nav__item::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
  transform: translateX(-100%);
  transition: transform 0.5s ease;
}

.admin-nav__item:hover::before {
  transform: translateX(100%);
}

.admin-nav__indicator {
  position: absolute;
  right: 1rem;
  top: 50%;
  transform: translateY(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--clr-accent);
  box-shadow: 0 0 8px var(--clr-accent);
  animation: indicatorPulse 2s ease-in-out infinite;
}

@keyframes indicatorPulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--clr-accent); }
  50% { opacity: 0.6; box-shadow: 0 0 16px var(--clr-primary), 0 0 4px var(--clr-accent); }
}

/* ── Admin Topbar ────────────────────────────────────── */
.admin-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem 2.25rem;
  background: #00594E !important;
  border-bottom: 3px solid #B5A160 !important;
  color: #FFFFFF !important;
  gap: 1.5rem;
  flex-wrap: wrap;
  position: sticky;
  top: 0;
  z-index: 50;
  box-shadow: 0 4px 20px rgba(0, 89, 78, 0.3);
}

.admin-topbar__left {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.admin-topbar__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.74rem;
  font-weight: 800;
  letter-spacing: 0.06em;
  color: #B5A160 !important;
  text-transform: uppercase;
}

[data-theme="dark"] .admin-topbar__badge {
  color: #B5A160 !important;
}

.pulse-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--clr-success);
  box-shadow: 0 0 8px var(--clr-success);
  animation: pulseDot 1.5s infinite ease-in-out;
}

@keyframes pulseDot {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.4); opacity: 0.6; }
}

.admin-topbar__title {
  font-size: 1.35rem;
  font-weight: 800;
  color: #FFFFFF !important;
  margin: 0;
  line-height: 1.2;
}

.admin-topbar__right {
  display: flex;
  align-items: center;
  gap: 1.25rem;
}

.admin-topbar__divider {
  width: 1px;
  height: 28px;
  background: rgba(181, 161, 96, 0.4) !important;
}

/* ── Logout button ───────────────────────────────────── */
.btn--logout {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.65rem 1.2rem;
  border-radius: 100px;
  font-family: var(--font-sans);
  font-size: 0.85rem;
  font-weight: 700;
  cursor: pointer;
  border: 1.5px solid #ef4444 !important;
  background: rgba(239, 68, 68, 0.25) !important;
  color: #FFFFFF !important;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  text-decoration: none;
  white-space: nowrap;
  width: 100%;
  position: relative;
  overflow: hidden;
}

.btn--logout::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(239, 68, 68, 0.18), rgba(239, 68, 68, 0.06));
  opacity: 0;
  transition: opacity 0.25s ease;
}

.btn--logout:hover {
  border-color: var(--clr-error);
  background: rgba(239, 68, 68, 0.16);
  transform: translateY(-2px);
  box-shadow: 0 4px 14px rgba(239, 68, 68, 0.25);
}

.btn--logout:hover::before {
  opacity: 1;
}

.btn--logout svg {
  transition: transform 0.25s ease;
  flex-shrink: 0;
}

.btn--logout:hover svg {
  transform: translateX(3px);
}

/* ── Page enter animation ────────────────────────────── */
.admin-page-enter {
  animation: pageEnter 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

:global(.text-highlight-exis) {
  background: linear-gradient(135deg, #FFD700 0%, #F39C12 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  font-weight: 900;
  font-size: 1.15em;
  text-shadow: 0px 3px 12px rgba(243, 156, 18, 0.4);
  display: inline-block;
  padding-left: 0.1rem;
}
</style>

<script is:inline>
  window.abrirModalPassword = function() {
    const modal = document.getElementById('modal-password-overlay');
    const redirectInput = document.getElementById('password-redirect-url');
    if (redirectInput) redirectInput.value = window.location.pathname + window.location.search;
    if (modal) modal.classList.add('active');
  };

  window.cerrarModalPassword = function(e) {
    const modal = document.getElementById('modal-password-overlay');
    if (modal) {
      if (!e || e.target === modal || e.type === 'click' && !e.target.closest('.modal')) {
        modal.classList.remove('active');
      }
    }
  };

  window.validarFormularioPassword = function() {
    const nueva = document.getElementById('password_nueva').value;
    const conf = document.getElementById('password_confirmacion').value;
    const errorMsg = document.getElementById('password-error-msg');
    
    if (nueva !== conf) {
      if (errorMsg) {
        errorMsg.textContent = '⚠️ Las contraseñas nuevas no coinciden.';
        errorMsg.style.display = 'block';
      }
      return false;
    }
    if (nueva.length < 6) {
      if (errorMsg) {
        errorMsg.textContent = '⚠️ La contraseña debe tener al menos 6 caracteres.';
        errorMsg.style.display = 'block';
      }
      return false;
    }
    return true;
  };

  window.toggleSidebarDesktop = function() {
    const layout = document.querySelector('.admin-layout');
    const icon = document.getElementById('desktop-toggle-icon');
    if (!layout) return;
    
    const isCollapsed = layout.classList.toggle('sidebar-collapsed');
    if (icon) icon.textContent = isCollapsed ? '▶' : '◀';
    try {
      localStorage.setItem('admin_sidebar_collapsed', isCollapsed ? 'true' : 'false');
    } catch(e) {}
  };

  window.toggleSidebarMobile = function() {
    const sidebar = document.querySelector('.admin-sidebar');
    const icon = document.getElementById('mobile-hamburger-icon');
    if (!sidebar) return;
    
    const isOpen = sidebar.classList.toggle('mobile-open');
    if (icon) icon.textContent = isOpen ? '✕' : '☰';
  };

  // Cargar estado guardado de colapsar en escritorio al cargar el DOM
  document.addEventListener('DOMContentLoaded', () => {
    try {
      if (localStorage.getItem('admin_sidebar_collapsed') === 'true' && window.innerWidth > 900) {
        const layout = document.querySelector('.admin-layout');
        const icon = document.getElementById('desktop-toggle-icon');
        if (layout) layout.classList.add('sidebar-collapsed');
        if (icon) icon.textContent = '▶';
      }
    } catch(e) {}

    // Guard de sesión
    window.addEventListener('pageshow', (event) => {
      if (event.persisted) {
        const tieneSesion = document.cookie
          .split(';')
          .some(c => c.trim().startsWith('admin_nombre='));

        if (!tieneSesion) {
          const overlay = document.getElementById('session-guard-overlay');
          if (overlay) overlay.style.display = 'flex';
          window.location.replace('/admin');
        }
      }
    });

    // Efecto de loading en logout
    const logoutForm = document.getElementById('logout-form');
    const logoutBtn = document.getElementById('logout-btn');
    if (logoutForm && logoutBtn) {
      logoutForm.addEventListener('submit', () => {
        logoutBtn.setAttribute('disabled', 'true');
        logoutBtn.style.opacity = '0.5';
        logoutBtn.innerHTML = `
          <div class="spinner" style="width:14px;height:14px;border-width:2px;"></div>
          <span>Cerrando...</span>
        `;
      });
    }

    // Animación escalonada de stat-cards
    document.querySelectorAll('.stat-card').forEach((card, i) => {
      card.style.animation = `fadeInUp 0.5s ease ${0.1 + i * 0.08}s both`;
    });
  });
</script>
