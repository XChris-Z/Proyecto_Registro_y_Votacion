---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  activePage?: string;
}

const { title, activePage = '' } = Astro.props;

const navItems = [
  { href: '/admin/dashboard', icon: '📊', label: 'Dashboard', id: 'dashboard' },
  { href: '/admin/proyectos', icon: '📁', label: 'Proyectos', id: 'proyectos' },
  { href: '/admin/categorias', icon: '🏷️', label: 'Categorías', id: 'categorias' },
  { href: '/admin/asistentes', icon: '👥', label: 'Asistentes', id: 'asistentes' },
  { href: '/admin/resultados', icon: '🏆', label: 'Resultados', id: 'resultados' },
  { href: '/admin/historial', icon: '📜', label: 'Historial / Cierre', id: 'historial' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Cache-Control" content="no-store, no-cache, must-revalidate" />
    <meta http-equiv="Pragma" content="no-cache" />
    <meta http-equiv="Expires" content="0" />
    <title>{title} — Admin EventoVota</title>
    <link rel="icon" href="/logo.png" type="image/png" />
  </head>
  <body class="admin-body">
    <!-- Orbes de fondo animados -->
    <div class="admin-bg-orbs" aria-hidden="true">
      <div class="orb orb--1"></div>
      <div class="orb orb--2"></div>
      <div class="orb orb--3"></div>
    </div>

    <div class="admin-layout">
      <aside class="admin-sidebar">
        <div class="admin-sidebar__logo">
          <a href="/" class="site-logo" style="color:var(--clr-text);display:flex;align-items:center;gap:0.6rem;">
            <img src="/logo.png" alt="Logo Unitrópico" style="height:2.1rem;width:auto;" />
            <span style="font-weight:800;font-size:1.2rem;">EventoVota</span>
          </a>
          <p style="font-size:0.75rem;color:var(--clr-text-muted);margin-top:0.4rem;padding-left:0.25rem;">Panel Admin Unitrópico</p>
        </div>
        <nav class="admin-sidebar__nav">
          {navItems.map((item, i) => (
            <a
              href={item.href}
              class={`admin-nav__item ${activePage === item.id ? 'active' : ''}`}
              style={`animation-delay: ${i * 0.07}s`}
            >
              <span class="admin-nav__icon">{item.icon}</span>
              {item.label}
              {activePage === item.id && <span class="admin-nav__indicator"></span>}
            </a>
          ))}
        </nav>
        <div style="margin-top:auto;padding:1.5rem;">
          <form method="POST" action="/api/admin/logout" id="logout-form">
            <button type="submit" class="btn btn--logout btn--full" id="logout-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
              </svg>
              <span>Cerrar sesión</span>
            </button>
          </form>
        </div>
      </aside>

      <main class="admin-main" id="admin-main-content">
        <div style="display:flex;justify-content:flex-end;padding:1rem 2rem 0;align-items:center;gap:1rem;flex-shrink:0;">
          <span style="font-size:0.85rem;color:var(--clr-text-muted);">Tema:</span>
          <ThemeToggle />
        </div>
        <div class="admin-page-enter" style="flex:1;padding:1.5rem 2rem 3rem;">
          <slot />
        </div>
        <div style="width:100%;margin-top:auto;flex-shrink:0;">
          <Footer />
        </div>
      </main>
    </div>


    <!-- Overlay de bloqueo mientras redirige (evita flash de contenido si la sesión expiró) -->
    <div id="session-guard-overlay" style="display:none;position:fixed;inset:0;background:var(--clr-bg);z-index:9999;align-items:center;justify-content:center;flex-direction:column;gap:1rem;">
      <div class="spinner" style="width:32px;height:32px;"></div>
      <p style="color:var(--clr-text-muted);font-size:0.9rem;">Verificando sesión...</p>
    </div>
  </body>
</html>

<style>
/* ── Orbes de fondo ──────────────────────────────────── */
.admin-bg-orbs {
  position: fixed;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}

.orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  opacity: 0.07;
}

.orb--1 {
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, #6c63ff, transparent 70%);
  top: -200px;
  left: -100px;
  animation: orbFloat1 18s ease-in-out infinite;
}

.orb--2 {
  width: 500px;
  height: 500px;
  background: radial-gradient(circle, #b06aff, transparent 70%);
  bottom: -150px;
  right: -100px;
  animation: orbFloat2 22s ease-in-out infinite;
}

.orb--3 {
  width: 350px;
  height: 350px;
  background: radial-gradient(circle, #f5c518, transparent 70%);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  animation: orbFloat3 15s ease-in-out infinite;
  opacity: 0.04;
}

@keyframes orbFloat1 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  33% { transform: translate(60px, 40px) scale(1.08); }
  66% { transform: translate(-30px, 70px) scale(0.95); }
}

@keyframes orbFloat2 {
  0%, 100% { transform: translate(0, 0) scale(1); }
  50% { transform: translate(-80px, -50px) scale(1.12); }
}

@keyframes orbFloat3 {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 0.04; }
  50% { transform: translate(-50%, -50%) scale(1.3); opacity: 0.07; }
}

/* ── Admin body ──────────────────────────────────────── */
.admin-body {
  position: relative;
}

/* ── Sidebar enhancements ────────────────────────────── */
.admin-sidebar {
  position: relative;
  z-index: 1;
}

.admin-sidebar__nav {
  display: flex;
  flex-direction: column;
  padding: 0.5rem 0;
}

.admin-nav__item {
  position: relative;
  overflow: hidden;
  animation: slideInLeft 0.4s ease both;
}

@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(-16px); }
  to   { opacity: 1; transform: translateX(0); }
}

.admin-nav__icon {
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  display: inline-block;
}

.admin-nav__item:hover .admin-nav__icon {
  transform: scale(1.2) rotate(-5deg);
}

/* Shimmer hover effect on nav items */
.admin-nav__item::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
  transform: translateX(-100%);
  transition: transform 0.5s ease;
}

.admin-nav__item:hover::before {
  transform: translateX(100%);
}

.admin-nav__indicator {
  position: absolute;
  right: 1rem;
  top: 50%;
  transform: translateY(-50%);
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--clr-primary-light);
  box-shadow: 0 0 8px var(--clr-primary-light);
  animation: indicatorPulse 2s ease-in-out infinite;
}

@keyframes indicatorPulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--clr-primary-light); }
  50% { opacity: 0.6; box-shadow: 0 0 16px var(--clr-primary), 0 0 4px var(--clr-primary-light); }
}

/* ── Logout button ───────────────────────────────────── */
.btn--logout {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  padding: 0.6rem 1rem;
  border-radius: var(--radius-sm);
  font-family: var(--font-sans);
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  border: 1px solid rgba(255, 87, 87, 0.2);
  background: rgba(255, 87, 87, 0.06);
  color: rgba(240, 240, 255, 0.5);
  transition: all 0.25s ease;
  text-decoration: none;
  white-space: nowrap;
  width: 100%;
  position: relative;
  overflow: hidden;
}

.btn--logout::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,87,87,0.12), rgba(255,107,107,0.06));
  opacity: 0;
  transition: opacity 0.25s ease;
}

.btn--logout:hover {
  border-color: rgba(255, 87, 87, 0.5);
  color: #ff5757;
  transform: translateY(-1px);
  box-shadow: 0 4px 16px rgba(255, 87, 87, 0.2);
}

.btn--logout:hover::before {
  opacity: 1;
}

.btn--logout svg {
  transition: transform 0.25s ease;
  flex-shrink: 0;
}

.btn--logout:hover svg {
  transform: translateX(3px);
}

/* ── Page enter animation ────────────────────────────── */
.admin-page-enter {
  animation: pageEnter 0.45s cubic-bezier(0.22, 1, 0.36, 1) both;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(12px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
</style>

<script>
  // ── Guard de sesión: detecta navegación por historial (botón "atrás") ──
  // El evento 'pageshow' se dispara al restaurar una página del caché del navegador.
  // persisted=true significa que viene del bfcache (back-forward cache).
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      // La página fue restaurada del caché; verificar si la sesión aún existe
      const tieneSesion = document.cookie
        .split(';')
        .some(c => c.trim().startsWith('admin_nombre='));

      if (!tieneSesion) {
        // Mostrar overlay y redirigir al login
        const overlay = document.getElementById('session-guard-overlay');
        if (overlay) {
          overlay.style.display = 'flex';
        }
        // Reemplazar la entrada de historial para evitar volver atrás
        window.location.replace('/admin');
      }
    }
  });

  // ── Efecto de loading en logout ──
  const logoutForm = document.getElementById('logout-form');
  const logoutBtn = document.getElementById('logout-btn');

  if (logoutForm && logoutBtn) {
    logoutForm.addEventListener('submit', () => {
      logoutBtn.setAttribute('disabled', 'true');
      logoutBtn.style.opacity = '0.5';
      logoutBtn.innerHTML = `
        <div class="spinner" style="width:14px;height:14px;border-width:2px;"></div>
        <span>Cerrando...</span>
      `;
    });
  }

  // ── Animación escalonada de stat-cards al cargar ──
  document.querySelectorAll<HTMLElement>('.stat-card').forEach((card, i) => {
    card.style.animation = `fadeInUp 0.5s ease ${0.1 + i * 0.08}s both`;
  });
</script>
