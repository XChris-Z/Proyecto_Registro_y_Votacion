---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import { ViewTransitions } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
}

import { obtenerJornadaActual } from '../lib/db';

const { title, description } = Astro.props;
const jornadaActual = await obtenerJornadaActual();
const siteName = jornadaActual.nombre || 'Votación EXIS 9.ª edición';
const siteDesc = description || jornadaActual.descripcion || 'Sistema Institucional de Registro y Votación — Unitrópico';
const highlightedSiteName = siteName.replace(/EXIS/g, '<span class="text-highlight-exis">EXIS</span>');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={siteDesc} />
    <title>{title} — {siteName}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <ViewTransitions />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <div class="site-header__inner">
          <a href="/" class="site-logo">
            <img src="/logo.png" alt="Logo Unitrópico" class="site-logo__img" />
            <span class="site-logo__text" set:html={highlightedSiteName}></span>
          </a>
          <nav style="display:flex;gap:0.75rem;align-items:center;">
            <a href="/" class="btn btn--outline btn--sm">Registro</a>
            <a href="/votacion" class="btn btn--primary btn--sm">Votar</a>
            <a
              href="/admin"
              class="admin-nav-btn"
              title="Panel de Administración"
              aria-label="Iniciar sesión como administrador"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="m9 12 2 2 4-4"/>
              </svg>
              <span class="admin-nav-btn__label">Admin</span>
            </a>
            <div style="width:1px;height:24px;background:rgba(255, 255, 255, 0.25);margin:0 0.15rem;" class="hide-mobile" aria-hidden="true"></div>
            <ThemeToggle />
          </nav>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <Footer />

    <style>
      .site-logo {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        text-decoration: none;
      }
      .site-logo__img {
        height: 2.4rem;
        width: auto;
        object-fit: contain;
      }
      .site-logo__text {
        font-weight: 800;
        font-size: 1.35rem;
        color: #FFFFFF;
        letter-spacing: -0.02em;
        display: flex;
        align-items: center;
        gap: 0.3rem;
      }
      :global(.text-highlight-exis) {
        background: linear-gradient(135deg, #FFD700 0%, #F39C12 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 900;
        font-size: 1.15em;
        text-shadow: 0px 3px 12px rgba(243, 156, 18, 0.4);
        display: inline-block;
        padding-left: 0.1rem;
      }
    </style>

    <script is:inline>
      document.addEventListener('astro:page-load', () => {
        // Automatically add reveal classes to certain elements if they don't have it
        const elementsToAnimate = document.querySelectorAll('.card, .vote-card, .category-section, .live-stat-box');
        elementsToAnimate.forEach(el => {
          if (!el.classList.contains('reveal-on-scroll')) {
            el.classList.add('reveal-on-scroll');
          }
        });

        const observerOptions = {
          root: null,
          rootMargin: '0px 0px -50px 0px',
          threshold: 0.1
        };

        const observer = new IntersectionObserver((entries, observer) => {
          let delayCounter = 0;
          let delayTimeout = null;
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.style.transitionDelay = `${delayCounter * 0.1}s`;
              delayCounter++;
              clearTimeout(delayTimeout);
              delayTimeout = setTimeout(() => {
                delayCounter = 0;
              }, 150);

              entry.target.classList.add('is-revealed');
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document.querySelectorAll('.reveal-on-scroll').forEach(el => {
          observer.observe(el);
        });

        // 3D Tilt Effect
        const tiltCards = document.querySelectorAll('.vote-card');
        if (window.matchMedia("(hover: hover) and (pointer: fine)").matches) {
          tiltCards.forEach(card => {
            card.addEventListener('mousemove', (e) => {
              const rect = card.getBoundingClientRect();
              const x = e.clientX - rect.left;
              const y = e.clientY - rect.top;
              const centerX = rect.width / 2;
              const centerY = rect.height / 2;
              const rotateX = ((y - centerY) / centerY) * -4;
              const rotateY = ((x - centerX) / centerX) * 4;
              card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-5px)`;
            });
            card.addEventListener('mouseleave', () => {
              card.style.transform = '';
            });
          });
        }
      });
    </script>
  </body>
</html>
